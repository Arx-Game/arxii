# Arx II Environment Configuration
# Copy this file to .env and fill in your actual values

# Core Django settings
DEBUG=True
SECRET_KEY=your-secret-key-here
DATABASE_URL=postgresql://user:password@localhost:5432/arxii

# Cloudinary configuration for media storage
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Email configuration (using Resend)
# Get API key from https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Frontend URL for email verification links
# For local dev: http://localhost:3000
# For ngrok testing: https://your-subdomain.ngrok-free.app
FRONTEND_URL=http://localhost:3000

# CSRF trusted origins (comma-separated, needed for ngrok testing)
# Example: CSRF_TRUSTED_ORIGINS=https://your-subdomain.ngrok-free.app
CSRF_TRUSTED_ORIGINS=

# Social authentication (Facebook)
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Social authentication (Google)
# Get credentials from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Social authentication (Discord)
# Get credentials from https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# Optional settings
SITE_DOMAIN=yourdomain.com
STAFF_NOTIFICATION_EMAILS=admin@yourdomain.com,staff@yourdomain.com

# Integration testing
# Set to 'true' to allow running integration tests with 'arx integration-test'
# This safety check prevents accidentally running integration tests in production
ALLOW_INTEGRATION_TESTS=false

# Integration test user credentials (used by arx integration-test)
# The script will create this user if it doesn't exist
INTEGRATION_TEST_USERNAME=integration_test_user
INTEGRATION_TEST_PASSWORD=IntegrationTestPassword123!
INTEGRATION_TEST_EMAIL=integration_test@example.com

# Private content repository (optional)
# Set CONTENT_REPO_PATH to a local checkout of the private lore repo to enable
# `just load-content` / `just check-content` (builds + upserts authored content).
# Set CONTENT_REPO_URL to the repo URL so `just load-content` auto-clones it
# if the checkout doesn't exist yet (requires GH_TOKEN in the environment).
# Both are per-machine config — the repo is never named in the codebase.
# CONTENT_REPO_PATH=/home/vscode/ArxII-lore
# CONTENT_REPO_URL=your-org/your-private-content-repo
