      - story
    UserStoryMuteCreate:
      type: object
      description: Input serializer for POST /api/narrative/story-mutes/.
      properties:
        story:
          type: integer
      required:
      - story
    UserStoryMuteCreateRequest:
      type: object
      description: Input serializer for POST /api/narrative/story-mutes/.
      properties:
        story:
          type: integer
      required:
      - story
    VisibilityF91Enum:
      enum:
      - default
      - very_private
      type: string
      description: |-
        * `default` - Default
        * `very_private` - Very Private
    VitalsFatigue:
      type: object
      description: All three fatigue pools plus global flags.
      properties:
        physical:
          $ref: '#/components/schemas/FatiguePoolStatus'
        social:
          $ref: '#/components/schemas/FatiguePoolStatus'
        mental:
          $ref: '#/components/schemas/FatiguePoolStatus'
        well_rested:
          type: boolean
        rested_today:
          type: boolean
      required:
      - mental
      - physical
      - rested_today
      - social
      - well_rested
    WeeklyVote:
      type: object
      description: Read serializer for WeeklyVote instances.
      properties:
        id:
          type: integer
          readOnly: true
        target_type:
          $ref: '#/components/schemas/WeeklyVoteTargetTypeEnum'
        target_id:
          type: integer
          maximum: 2147483647
          minimum: 0
          description: PK of the voted-on object (not a FK -- no cascades)
        target_name:
          type: string
          description: Resolve a human-readable name for the vote target.
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - created_at
      - id
      - target_id
      - target_name
      - target_type
    WeeklyVoteRequest:
      type: object
      description: Read serializer for WeeklyVote instances.
      properties:
        target_type:
          $ref: '#/components/schemas/WeeklyVoteTargetTypeEnum'
        target_id:
          type: integer
          maximum: 2147483647
          minimum: 0
          description: PK of the voted-on object (not a FK -- no cascades)
      required:
      - target_id
      - target_type
    WeeklyVoteTargetTypeEnum:
      enum:
      - interaction
      - scene_participation
      - journal
      type: string
      description: |-
        * `interaction` - Interaction
        * `scene_participation` - Scene Participation
        * `journal` - Journal Entry
    WindowReactInput:
      type: object
      properties:
        persona_id:
          type: integer
          description: PK of the Persona reacting (must belong to the requester).
        choice:
          type: string
          description: Slug from the window's choices payload.
          maxLength: 64
      required:
      - choice
      - persona_id
    WindowReactInputRequest:
      type: object
      properties:
        persona_id:
          type: integer
          description: PK of the Persona reacting (must belong to the requester).
        choice:
          type: string
          minLength: 1
          description: Slug from the window's choices payload.
          maxLength: 64
      required:
      - choice
      - persona_id
    _CategoryPolish:
      type: object
      description: One polish category's value + derived tier label for a building.
      properties:
        category_id:
          type: integer
        category_name:
          type: string
        value:
          type: integer
        tier_label:
          type: string
          nullable: true
      required:
      - category_id
      - category_name
      - tier_label
      - value
    _Deed:
      type: object
      description: LegendEntry summary for the recent-deeds list.
      properties:
        id:
          type: integer
        title:
          type: string
        base_value:
          type: integer
        created_at:
          type: string
          format: date-time
      required:
      - base_value
      - created_at
      - id
      - title
    _Fame:
      type: object
      description: Persona's fame state for the renown tab header.
      properties:
        points:
          type: integer
        tier:
          type: string
        tier_label:
          type: string
        tier_multiplier:
          type: number
          format: double
        next_tier:
          type: string
          nullable: true
        next_tier_threshold:
          type: integer
          nullable: true
      required:
      - next_tier
      - next_tier_threshold
      - points
      - tier
      - tier_label
      - tier_multiplier
    _NearXPLockProspect:
      type: object
      description: One entry in the near-xp-lock list returned by ThreadHubSummaryView.
      properties:
        thread_id:
          type: integer
        boundary_level:
          type: integer
        xp_cost:
          type: integer
        dev_points_to_boundary:
          type: integer
      required:
      - boundary_level
      - dev_points_to_boundary
      - thread_id
      - xp_cost
    _OwnedDwelling:
      type: object
      description: One building the persona owns, with polish breakdown + upkeep state.
      properties:
        id:
          type: integer
        name:
          type: string
        polish_by_category:
          type: array
          items:
            $ref: '#/components/schemas/_CategoryPolish'
        upkeep_warning:
          type: boolean
        decayed_features_count:
          type: integer
        dormant:
          type: boolean
        dormant_since:
          type: string
          format: date-time
          nullable: true
      required:
      - decayed_features_count
      - dormant
      - dormant_since
      - id
      - name
      - polish_by_category
      - upkeep_warning
    _PrestigeBreakdown:
      type: object
      description: Four-axis breakdown of the persona's total_prestige.
      properties:
        dwellings:
          type: integer
        items:
          type: integer
        orgs:
          type: integer
        deeds:
          type: integer
        total:
          type: integer
      required:
      - deeds
      - dwellings
      - items
      - orgs
      - total
    _RenownCardFame:
      type: object
      description: |-
        Fame block on the card — tier label only.

        The full Renown tab exposes numeric fame_points + multiplier for
        the player's own personas; foreign personas show just the tier
        label (the spec is explicit about no numeric reveal).
      properties:
        tier:
          type: string
        tier_label:
          type: string
      required:
      - tier
      - tier_label
    _ResonanceBalance:
      type: object
      description: One resonance balance entry returned by ThreadHubSummaryView.
      properties:
        resonance_id:
          type: integer
        balance:
          type: integer
        lifetime_earned:
          type: integer
        flavor_text:
          type: string
      required:
      - balance
      - flavor_text
      - lifetime_earned
      - resonance_id
    _SocietyReputation:
      type: object
      description: 'One reputation entry: society + tier label (no raw number).'
      properties:
        society_id:
          type: integer
        society_name:
          type: string
        tier:
          type: string
      required:
      - society_id
      - society_name
      - tier
    _TenantedRoom:
      type: object
      description: |-
        One room the persona tenants — polish breakdown only, no upkeep/dormancy.

        Upkeep + dormancy are building-level concepts; rooms don't carry
        them directly. The room's containing building's upkeep state shows
        up in ``owned_dwellings`` separately (when the persona owns it).
      properties:
        id:
          type: integer
        name:
          type: string
        polish_by_category:
          type: array
          items:
            $ref: '#/components/schemas/_CategoryPolish'
      required:
      - id
      - name
      - polish_by_category
    _WeavableTechnique:
      type: object
      description: One entry in the weavable_techniques list.
      properties:
        technique_id:
          type: integer
        name:
          type: string
        gift_id:
          type: integer
        gift_name:
          type: string
      required:
      - gift_id
      - gift_name
      - name
      - technique_id
    _WeavableTrait:
      type: object
      description: One entry in the weavable_traits list.
      properties:
        trait_id:
          type: integer
        name:
          type: string
        trait_type:
          type: string
        display_value:
          type: number
          format: double
      required:
      - display_value
      - name
      - trait_id
      - trait_type
  securitySchemes:
    cookieAuth:
      type: apiKey
      in: cookie
      name: sessionid
