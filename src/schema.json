    PendingAudereMajoraOffer:
      type: object
      description: |-
        Player-facing view of a pending Audere Majora (Crossing) offer (#543). Read-only.

        advisory_text is computed live so the corruption warning is always current.
        eligible_paths is computed per-object and memoized to avoid N+1 queries.
      properties:
        id:
          type: integer
          readOnly: true
        character_sheet_id:
          type: integer
          readOnly: true
        character_name:
          type: string
          description: IC display name via the primary persona.
          readOnly: true
        fired_intensity:
          type: integer
          readOnly: true
          description: Runtime intensity of the cast that opened the gate.
        soulfray_stage_order:
          type: integer
          readOnly: true
          description: Soulfray stage order at fire time (display snapshot).
        boundary_level:
          type: integer
          readOnly: true
        target_stage_display:
          type: string
          description: Human-readable label for the target PathStage.
          readOnly: true
        vision_text:
          type: string
          readOnly: true
        advisory_text:
          type: string
          description: Live corruption advisory; empty string when no stage-3+ corruption.
          readOnly: true
        risk_text:
          type: string
          description: Fixed risk copy (approved verbatim).
          readOnly: true
        eligible_paths:
          type: array
          items:
            $ref: '#/components/schemas/EligiblePath'
          readOnly: true
        intended_path_id:
          type: integer
          nullable: true
          description: Return the PathIntent's intended_path_id if it is among eligible
            paths, else None.
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - advisory_text
      - boundary_level
      - character_name
      - character_sheet_id
      - created_at
      - eligible_paths
      - fired_intensity
      - id
      - intended_path_id
      - risk_text
      - soulfray_stage_order
      - target_stage_display
      - vision_text
    PendingAudereOffer:
      type: object
      description: |-
        Player-facing view of a pending Audere offer (#873). Read-only.

        advisory_text is computed live (never stored) so the corruption
        "character loss" warning is always current.
      properties:
        id:
          type: integer
          readOnly: true
        character_sheet_id:
          type: integer
          readOnly: true
        character_name:
          type: string
          description: IC display name via the primary persona.
          readOnly: true
        fired_intensity:
          type: integer
          readOnly: true
          description: Runtime intensity of the cast that opened the gate.
        soulfray_stage_order:
          type: integer
          readOnly: true
          description: Soulfray stage order at fire time (display snapshot).
        intensity_bonus:
          type: integer
          description: Intensity bonus the offer would grant (from the global threshold
            config).
          readOnly: true
        anima_pool_bonus:
          type: integer
          description: Anima pool expansion the offer would grant (from the global
            threshold config).
          readOnly: true
        advisory_text:
          type: string
          description: Live corruption advisory; empty string when no stage-3+ corruption.
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - advisory_text
      - anima_pool_bonus
      - character_name
      - character_sheet_id
      - created_at
      - fired_intensity
      - id
      - intensity_bonus
      - soulfray_stage_order
    PendingCrossingOffer:
