          description: |-
            Difficulty level chosen or determined for this action

            * `trivial` - Trivial
            * `easy` - Easy
            * `normal` - Normal
            * `hard` - Hard
            * `daunting` - Daunting
        resolved_difficulty:
          type: integer
          readOnly: true
          nullable: true
          description: The numeric difficulty used for resolution
        result_interaction:
          type: integer
          readOnly: true
          nullable: true
          description: The interaction recording the result of this action
        action_interaction:
          type: integer
          readOnly: true
          nullable: true
          description: ACTION-mode Interaction for this cast (carries the power ledger).
        strain_commitment:
          type: integer
          maximum: 2147483647
          minimum: 0
          description: Extra anima the player commits beyond base cost. Bounded by
            available anima at resolution time.
        combat_risk_level:
          type: string
          nullable: true
          description: Risk level of the encounter a PENDING hostile cast would pull
            the target into (#777).
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        resolved_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
          description: When this action was resolved
