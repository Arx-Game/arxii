          $ref: '#/components/schemas/Status4e6Enum'
        outcome:
          allOf:
          - $ref: '#/components/schemas/Outcome88eEnum'
          readOnly: true
          description: |-
            Typed result recorded at completion (#876); empty until completed.

            * `victory` - Victory
            * `defeat` - Defeat
            * `fled` - Fled
            * `abandoned` - Abandoned
        completed_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
