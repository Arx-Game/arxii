openapi: 3.0.3
info:
  title: Arx II API
  version: 0.1.0
  description: API for Arx II MUD web interface
paths:
  /api/achievements/achievements/:
    get:
      operationId: achievements_achievements_list
      description: |-
        ViewSet for listing and retrieving achievements.

        Returns active achievements that are either visible (not hidden) or
        have been earned by the requesting user's characters.
      parameters:
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      tags:
      - achievements
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/AchievementList'
          description: ''
  /api/achievements/achievements/{id}/:
    get:
      operationId: achievements_achievements_retrieve
      description: |-
        ViewSet for listing and retrieving achievements.

        Returns active achievements that are either visible (not hidden) or
        have been earned by the requesting user's characters.
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - achievements
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Achievement'
          description: ''
  /api/achievements/character-achievements/:
    get:
      operationId: achievements_character_achievements_list
      description: |-
        ViewSet for listing character achievements.

        Returns achievements earned by characters, filterable by character_sheet.
      parameters:
      - in: query
        name: character_sheet
        schema:
          type: integer
      tags:
      - achievements
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/CharacterAchievement'
          description: ''
  /api/achievements/character-achievements/{id}/:
    get:
      operationId: achievements_character_achievements_retrieve
      description: |-
        ViewSet for listing character achievements.

        Returns achievements earned by characters, filterable by character_sheet.
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this character achievement.
        required: true
      tags:
      - achievements
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CharacterAchievement'
          description: ''
  /api/action-requests/:
    get:
      operationId: action_requests_list
      description: ViewSet for scene action requests with consent flow.
      parameters:
      - in: query
        name: initiator
        schema:
          type: number
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - in: query
        name: scene
        schema:
          type: number
      - in: query
        name: status
        schema:
          type: string
      - in: query
        name: target
        schema:
          type: number
      tags:
      - action-requests
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedSceneActionRequestList'
          description: ''
    post:
      operationId: action_requests_create
      description: Create a new action request.
      tags:
      - action-requests
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/SceneActionRequestRequest'
        required: true
      security:
      - cookieAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SceneActionRequest'
          description: ''
  /api/action-requests/{id}/:
    get:
      operationId: action_requests_retrieve
      description: ViewSet for scene action requests with consent flow.
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this scene action request.
        required: true
      tags:
      - action-requests
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SceneActionRequest'
          description: ''
  /api/action-requests/{id}/respond/:
    post:
      operationId: action_requests_respond_create
      description: Respond to a pending action request (accept/deny).
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this scene action request.
        required: true
      tags:
      - action-requests
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/SceneActionRequestRequest'
        required: true
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SceneActionRequest'
          description: ''
  /api/action-requests/cast/:
    post:
      operationId: action_requests_cast_create
      description: |-
        Submit a standalone technique cast.

        Routes per the consent/combat/immediate matrix:
        - self/room/no-target → resolves immediately (201 with result + power_ledger)
        - benign at another PC → PENDING consent request (201, no result yet)
        - hostile at another PC → seeds/feeds a combat encounter (201 with encounter summary)
      tags:
      - action-requests
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/SceneActionRequestRequest'
        required: true
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SceneActionRequest'
          description: ''
  /api/action-requests/castable-techniques/:
    get:
      operationId: action_requests_castable_techniques_retrieve
      description: |-
        List techniques the given persona can cast standalone.

        Requires ?initiator_persona=<id> query param. Returns only techniques
        with an action_template (castable standalone) known by that character.
      tags:
      - action-requests
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SceneActionRequest'
          description: ''
  /api/actions/characters/{character_id}/available/:
    get:
      operationId: actions_characters_available_list
      description: |-
        Available actions for a character — merged challenge + combat backends.

        Returns all PlayerAction descriptors available to the character right now.
        Recomputed on every request; no caching.
      parameters:
      - in: path
        name: character_id
        schema:
          type: integer
        required: true
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: page_size
        required: false
        in: query
        description: Number of results to return per page.
        schema:
          type: integer
      tags:
      - actions
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedPlayerActionList'
          description: ''
  /api/actions/characters/{character_id}/dispatch/:
    post:
      operationId: actions_characters_dispatch_create
      description: Dispatch the given action ref for character_id.
      parameters:
      - in: path
        name: character_id
        schema:
          type: integer
        required: true
      tags:
      - actions
      security:
      - cookieAuth: []
      responses:
        '200':
          description: No response body
  /api/aggregate-beat-contributions/:
    get:
      operationId: aggregate_beat_contributions_list
      description: |-
        Read-only ViewSet for AggregateBeatContribution.

        Writes go through record_aggregate_contribution service (Wave 11 action endpoints).
        Read access: the contributing character's account, story Lead GM (owner), or staff.
      parameters:
      - in: query
        name: beat
        schema:
          type: number
      - in: query
        name: character_sheet
        schema:
          type: number
      - in: query
        name: episode
        schema:
          type: number
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: page_size
        required: false
        in: query
        description: Number of results to return per page.
        schema:
          type: integer
      - in: query
        name: recorded_after
        schema:
          type: string
          format: date-time
      - in: query
        name: recorded_before
        schema:
          type: string
          format: date-time
      - in: query
        name: story
        schema:
          type: number
      tags:
      - aggregate-beat-contributions
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedAggregateBeatContributionList'
          description: ''
  /api/aggregate-beat-contributions/{id}/:
    get:
      operationId: aggregate_beat_contributions_retrieve
      description: |-
        Read-only ViewSet for AggregateBeatContribution.

        Writes go through record_aggregate_contribution service (Wave 11 action endpoints).
        Read access: the contributing character's account, story Lead GM (owner), or staff.
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this aggregate beat contribution.
        required: true
      tags:
      - aggregate-beat-contributions
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AggregateBeatContribution'
          description: ''
  /api/areas/:
    get:
      operationId: areas_list
      description: Browse the area hierarchy for room selection.
      parameters:
      - in: query
        name: has_parent
        schema:
          type: boolean
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: page_size
        required: false
        in: query
        description: Number of results to return per page.
        schema:
          type: integer
      - in: query
        name: parent
        schema:
          type: number
      tags:
      - areas
      security:
      - cookieAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedAreaListList'
          description: ''
  /api/areas/{id}/:
    get:
      operationId: areas_retrieve
      description: Browse the area hierarchy for room selection.
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this Area.
        required: true
      tags:
      - areas
      security:
      - cookieAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AreaList'
          description: ''
  /api/areas/rooms/:
    get:
      operationId: areas_rooms_list
      description: Browse public rooms, filterable by area (includes descendant areas).
      parameters:
      - in: query
        name: area
        schema:
          type: integer
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: page_size
        required: false
        in: query
        description: Number of results to return per page.
        schema:
          type: integer
      tags:
      - areas
      security:
      - cookieAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedAreaRoomList'
          description: ''
  /api/areas/rooms/{id}/:
    get:
      operationId: areas_rooms_retrieve
      description: Browse public rooms, filterable by area (includes descendant areas).
      parameters:
      - in: path
        name: id
        schema:
          type: string
        required: true
      tags:
      - areas
      security:
      - cookieAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AreaRoom'
          description: ''
  /api/assistant-gm-claims/:
    get:
      operationId: assistant_gm_claims_list
      description: |-
        ViewSet for AssistantGMClaim.

        Read: ReadOnlyModelViewSet (list + retrieve).
        State transitions: custom @action endpoints (Wave 11):
          POST /api/assistant-gm-claims/request/ — request_claim
          POST /api/assistant-gm-claims/{id}/approve/ — approve_claim
          POST /api/assistant-gm-claims/{id}/reject/  — reject_claim
          POST /api/assistant-gm-claims/{id}/cancel/  — cancel_claim
          POST /api/assistant-gm-claims/{id}/complete/ — complete_claim

        Read access: the claiming AGM (assistant_gm.account), Lead GM (story owner), or staff.
      parameters:
      - in: query
        name: assistant_gm
        schema:
          type: number
      - in: query
        name: beat
        schema:
          type: number
      - in: query
        name: episode
        schema:
          type: number
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: page_size
        required: false
        in: query
        description: Number of results to return per page.
        schema:
          type: integer
      - in: query
        name: requested_after
        schema:
          type: string
          format: date-time
      - in: query
        name: status
        schema:
          type: string
      - in: query
        name: story
        schema:
          type: number
      tags:
      - assistant-gm-claims
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedAssistantGMClaimList'
          description: ''
  /api/assistant-gm-claims/{id}/:
    get:
      operationId: assistant_gm_claims_retrieve
      description: |-
        ViewSet for AssistantGMClaim.

        Read: ReadOnlyModelViewSet (list + retrieve).
        State transitions: custom @action endpoints (Wave 11):
          POST /api/assistant-gm-claims/request/ — request_claim
          POST /api/assistant-gm-claims/{id}/approve/ — approve_claim
          POST /api/assistant-gm-claims/{id}/reject/  — reject_claim
          POST /api/assistant-gm-claims/{id}/cancel/  — cancel_claim
          POST /api/assistant-gm-claims/{id}/complete/ — complete_claim

        Read access: the claiming AGM (assistant_gm.account), Lead GM (story owner), or staff.
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this assistant gm claim.
        required: true
      tags:
      - assistant-gm-claims
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AssistantGMClaim'
          description: ''
  /api/assistant-gm-claims/{id}/approve/:
    post:
      operationId: assistant_gm_claims_approve_create
      description: |-
        POST /api/assistant-gm-claims/{id}/approve/ — Lead GM approves the claim.

        IsGMProfile ensures request.user.gm_profile is always accessible.
        IsLeadGMOnClaimStoryOrStaff confirms Lead GM role on the claim's story.
        Status validation handled by ApproveClaimInputSerializer.
        Returns 200 with the updated claim.
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this assistant gm claim.
        required: true
      tags:
      - assistant-gm-claims
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AssistantGMClaim'
          description: ''
  /api/assistant-gm-claims/{id}/cancel/:
    post:
      operationId: assistant_gm_claims_cancel_create
      description: |-
        POST /api/assistant-gm-claims/{id}/cancel/ — the AGM cancels their own claim.

        Status validation (must be REQUESTED) handled by CancelClaimInputSerializer.
        Returns 200 with the updated claim.
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this assistant gm claim.
        required: true
      tags:
      - assistant-gm-claims
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AssistantGMClaim'
          description: ''
  /api/assistant-gm-claims/{id}/complete/:
    post:
      operationId: assistant_gm_claims_complete_create
      description: |-
        POST /api/assistant-gm-claims/{id}/complete/ — Lead GM marks an approved claim done.

        IsGMProfile ensures request.user.gm_profile is always accessible.
        IsLeadGMOnClaimStoryOrStaff confirms Lead GM role on the claim's story.
        Status validation (must be APPROVED) handled by CompleteClaimInputSerializer.
        Returns 200 with the updated claim.
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this assistant gm claim.
        required: true
      tags:
      - assistant-gm-claims
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AssistantGMClaim'
          description: ''
  /api/assistant-gm-claims/{id}/reject/:
    post:
      operationId: assistant_gm_claims_reject_create
      description: |-
        POST /api/assistant-gm-claims/{id}/reject/ — Lead GM rejects the claim.

        IsGMProfile ensures request.user.gm_profile is always accessible.
        IsLeadGMOnClaimStoryOrStaff confirms Lead GM role on the claim's story.
        Status validation handled by RejectClaimInputSerializer.
        Returns 200 with the updated claim.
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this assistant gm claim.
        required: true
      tags:
      - assistant-gm-claims
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AssistantGMClaim'
          description: ''
  /api/assistant-gm-claims/request/:
    post:
      operationId: assistant_gm_claims_request_create
      description: |-
        POST /api/assistant-gm-claims/request/ — an AGM requests to run a beat.

        Requires a GMProfile (enforced by IsGMProfile). Beat existence and
        agm_eligible validation handled by RequestClaimInputSerializer.
        Returns 201 with the claim on success.
      tags:
      - assistant-gm-claims
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AssistantGMClaim'
          description: ''
  /api/auth/browser/v1/auth/email/request:
    post:
      operationId: auth_browser_v1_auth_email_request_create
      description: Resend verification email to current user or specified email.
      tags:
      - auth
      security:
      - cookieAuth: []
      - {}
      responses:
        '200':
          description: No response body
  /api/auth/browser/v1/auth/email/verify:
    post:
      operationId: auth_browser_v1_auth_email_verify_create
      description: Verify email using confirmation key.
      tags:
      - auth
      security:
      - cookieAuth: []
      - {}
      responses:
        '200':
          description: No response body
  /api/auth/browser/v1/auth/logout:
    post:
      operationId: auth_browser_v1_auth_logout_create
      description: Log out the current user.
      tags:
      - auth
      security:
      - cookieAuth: []
      - {}
      responses:
        '200':
          description: No response body
  /api/beats/:
    get:
      operationId: beats_list
      description: |-
        ViewSet for Beat — includes all Phase 2 predicate config fields.

        Access delegated to episode story ownership (same as EpisodeViewSet).
      parameters:
      - in: query
        name: agm_eligible
        schema:
          type: boolean
      - in: query
        name: episode
        schema:
          type: number
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: page_size
        required: false
        in: query
        description: Number of results to return per page.
        schema:
          type: integer
      - in: query
        name: story
        schema:
          type: number
      tags:
      - beats
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedBeatList'
          description: ''
    post:
      operationId: beats_create
      description: |-
        ViewSet for Beat — includes all Phase 2 predicate config fields.

        Access delegated to episode story ownership (same as EpisodeViewSet).
      tags:
      - beats
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/BeatRequest'
        required: true
      security:
      - cookieAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Beat'
          description: ''
  /api/beats/{id}/:
    get:
      operationId: beats_retrieve
      description: |-
        ViewSet for Beat — includes all Phase 2 predicate config fields.

        Access delegated to episode story ownership (same as EpisodeViewSet).
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this beat.
        required: true
      tags:
      - beats
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Beat'
          description: ''
    put:
      operationId: beats_update
      description: |-
        ViewSet for Beat — includes all Phase 2 predicate config fields.

        Access delegated to episode story ownership (same as EpisodeViewSet).
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this beat.
        required: true
      tags:
      - beats
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/BeatRequest'
        required: true
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Beat'
          description: ''
    patch:
      operationId: beats_partial_update
      description: |-
        ViewSet for Beat — includes all Phase 2 predicate config fields.

        Access delegated to episode story ownership (same as EpisodeViewSet).
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this beat.
        required: true
      tags:
      - beats
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedBeatRequest'
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Beat'
          description: ''
    delete:
      operationId: beats_destroy
      description: |-
        ViewSet for Beat — includes all Phase 2 predicate config fields.

        Access delegated to episode story ownership (same as EpisodeViewSet).
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this beat.
        required: true
      tags:
      - beats
      security:
      - cookieAuth: []
      responses:
        '204':
          description: No response body
  /api/beats/{id}/contribute/:
    post:
      operationId: beats_contribute_create
      description: |-
        POST /api/beats/{id}/contribute/ — record a character contribution to an AGGREGATE beat.

        The requesting user must own the character_sheet (or be staff), validated
        by ContributeBeatInputSerializer. Wraps record_aggregate_contribution.
        Returns 201 with contribution on success.
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this beat.
        required: true
      tags:
      - beats
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/BeatRequest'
        required: true
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Beat'
          description: ''
  /api/beats/{id}/mark/:
    post:
      operationId: beats_mark_create
      description: |-
        POST /api/beats/{id}/mark/ — GM marks the outcome of a GM_MARKED beat.

