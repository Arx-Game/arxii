        is_active:
          type: boolean
          description: Whether this category is currently in use
      required:
      - description
      - display_name
      - name
    UpdateBulletinPostInput:
      type: object
      description: |-
        Input for PATCH /api/table-bulletin-posts/{id}/.

        Only the post author (Lead GM of the table) or staff may edit.
        No field is required; all are optional.
      properties:
        title:
          type: string
          maxLength: 200
        body:
          type: string
        allow_replies:
          type: boolean
    UpdateBulletinPostInputRequest:
      type: object
      description: |-
        Input for PATCH /api/table-bulletin-posts/{id}/.

        Only the post author (Lead GM of the table) or staff may edit.
        No field is required; all are optional.
      properties:
        title:
          type: string
          minLength: 1
          maxLength: 200
        body:
          type: string
          minLength: 1
        allow_replies:
          type: boolean
    UpdateBulletinReplyInput:
      type: object
      description: |-
        Input for PATCH /api/table-bulletin-replies/{id}/.

        Only the reply author or staff may edit.
      properties:
        body:
          type: string
      required:
      - body
    UpdateBulletinReplyInputRequest:
      type: object
      description: |-
        Input for PATCH /api/table-bulletin-replies/{id}/.

        Only the reply author or staff may edit.
      properties:
        body:
          type: string
          minLength: 1
      required:
      - body
    UserStoryMute:
      type: object
