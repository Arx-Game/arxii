    PoseEndorsement:
      type: object
      description: |-
        Serializer for PoseEndorsement create + read (Spec C Task 23).

        Write: accepts ``interaction`` + ``resonance`` PKs from the request body.
        The ``endorser_sheet`` is resolved from the requesting account in the
        view (``PoseEndorsementViewSet.perform_create``) and injected via
        ``serializer.save(endorser_sheet=sheet)``.

        Read: all fields are present; read-only fields cannot be supplied by the
        client.
      properties:
        id:
          type: integer
          readOnly: true
        endorser_sheet:
          type: integer
          description: The character this sheet belongs to
          readOnly: true
        endorsee_sheet:
          type: integer
          description: The character this sheet belongs to
          readOnly: true
        interaction:
          type: integer
          description: The interaction being endorsed.
        resonance:
          type: integer
        persona_snapshot:
          type: integer
          readOnly: true
          nullable: true
          description: Endorsee's persona at endorsement time — captures masquerade
            for audit.
        created_at:
          type: string
          format: date-time
          readOnly: true
        settled_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
        granted_amount:
          type: integer
          readOnly: true
          nullable: true
          description: Set at weekly settlement.
      required:
      - created_at
      - endorsee_sheet
      - endorser_sheet
      - granted_amount
      - id
      - interaction
      - persona_snapshot
      - resonance
      - settled_at
    PoseEndorsementRequest:
      type: object
      description: |-
        Serializer for PoseEndorsement create + read (Spec C Task 23).

        Write: accepts ``interaction`` + ``resonance`` PKs from the request body.
        The ``endorser_sheet`` is resolved from the requesting account in the
        view (``PoseEndorsementViewSet.perform_create``) and injected via
        ``serializer.save(endorser_sheet=sheet)``.

        Read: all fields are present; read-only fields cannot be supplied by the
        client.
      properties:
        interaction:
          type: integer
          description: The interaction being endorsed.
        resonance:
          type: integer
      required:
      - interaction
      - resonance
