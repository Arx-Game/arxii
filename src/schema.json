      tags:
      - user
      security:
      - cookieAuth: []
      - {}
      responses:
        '200':
          description: No response body
  /api/vitals/{character_id}/:
    get:
      operationId: vitals_retrieve
      description: |-
        Read-only vitals payload for the character sheet page (#521).

        Visibility: staff, or an account with an active tenure on the character.
        Everyone else receives 404 (same queryset rule as CharacterAnimaViewSet).

        Hot path rides the SharedMemoryModel identity map: the sheet is resolved
        by pk and vitals/fatigue are read via the instance-cached reverse
        accessors — repeated calls re-query none of those rows.
      parameters:
      - in: path
        name: character_id
        schema:
          type: integer
        required: true
      tags:
      - vitals
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CharacterVitals'
          description: ''
  /api/weather/conditions/:
    get:
      operationId: weather_conditions_retrieve
      description: GET /conditions/?room_id=<id> — IC time + the weather holding at
        a room.
      parameters:
      - in: query
        name: room_id
        schema:
          type: integer
        description: ObjectDB id of the room to read conditions for.
        required: true
      tags:
      - weather
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Conditions'
          description: ''
  /api/world-builder/areas/:
    get:
      operationId: world_builder_areas_list
      description: Staff-only reads for the world-builder canvas (#2449).
      parameters:
      - in: query
        name: has_parent
        schema:
          type: boolean
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: page_size
        required: false
        in: query
        description: Number of results to return per page.
        schema:
          type: integer
      - in: query
        name: parent
        schema:
          type: number
      tags:
      - world-builder
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedWorldBuilderAreaList'
          description: ''
  /api/world-builder/areas/{id}/:
    get:
      operationId: world_builder_areas_retrieve
      description: Staff-only reads for the world-builder canvas (#2449).
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this Area.
        required: true
      tags:
      - world-builder
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/WorldBuilderArea'
          description: ''
  /api/world-builder/areas/{id}/manager/:
    get:
      operationId: world_builder_areas_manager_retrieve
      description: |-
        GET /api/world-builder/areas/<id>/manager/ — area + all rooms + exits.

        Unlike ``BuildingManagerViewSet.retrieve``, ``rooms`` includes every
        RoomProfile in the area regardless of ``is_public`` — staff editing
        the canvas needs to see (and select) private rooms too.
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this Area.
        required: true
      tags:
      - world-builder
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/WorldBuilderAreaManager'
          description: ''
  /api/worship/beings/:
    get:
      operationId: worship_beings_list
      description: |-
        Public catalog of active worshippable beings (the CG picker source).

        Exposes only the reference shape (id, name, tradition name) — pools,
        avatars, and worshipper lists never leave this endpoint.
      parameters:
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: page_size
        required: false
        in: query
        description: Number of results to return per page.
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      - in: query
        name: tradition
        schema:
          type: integer
      tags:
      - worship
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedWorshippedBeingRefList'
          description: ''
  /api/worship/beings/{id}/:
    get:
      operationId: worship_beings_retrieve
      description: |-
        Public catalog of active worshippable beings (the CG picker source).

        Exposes only the reference shape (id, name, tradition name) — pools,
        avatars, and worshipper lists never leave this endpoint.
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this worshipped being.
        required: true
      tags:
      - worship
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/WorshippedBeingRef'
          description: ''
components:
  schemas:
    AcceptSoulTetherRequest:
      type: object
      description: |-
        Write serializer for forming a Soul Tether (Spec B §12).

        ``actor_sheet_id`` identifies the character sheet of the requesting account.
        ``partner_sheet_id`` identifies the partner's character sheet.
        ``sinner_role`` determines which side (SINNER or SINEATER) the initiator holds.
        ``resonance_id`` selects the resonance for the Sinner's Thread.
        ``writeup`` is the narrative description of the bond (20+ chars).
      properties:
        actor_sheet_id:
          type: integer
        partner_sheet_id:
          type: integer
        sinner_role:
          $ref: '#/components/schemas/SinnerRoleEnum'
        resonance_id:
          type: integer
        writeup:
          type: string
          minLength: 20
          maxLength: 4000
      required:
      - actor_sheet_id
      - partner_sheet_id
      - resonance_id
      - sinner_role
      - writeup
    AcceptTeachingOfferRequest:
      type: object
      description: |-
        Serializer for accepting a ThreadWeavingTeachingOffer (Spec A §6.1).

        Optional ``learner_sheet_id`` disambiguates the learner when the requesting
        account has multiple active tenures (alt-guard).  The view provides the
        offer instance via serializer context as ``"offer"``.
      properties:
        learner_sheet_id:
          type: integer
          nullable: true
    AcceptTeachingOfferResponse:
      type: object
      description: |-
        Response shape for ThreadWeavingTeachingOfferViewSet.accept (Spec A §6.1).

        Returned by POST /api/magic/teaching-offers/{id}/accept/ on success.
      properties:
        id:
          type: integer
        unlock_id:
          type: integer
        xp_spent:
          type: integer
      required:
      - id
      - unlock_id
      - xp_spent
    AcceptTechniqueOfferRequestRequest:
      type: object
      description: Request shape for POST /api/magic/technique-offers/accept/.
      properties:
        offer_id:
          type: integer
        learner_sheet_id:
          type: integer
          nullable: true
      required:
      - offer_id
    AcceptTechniqueOfferResponse:
      type: object
      properties:
        offer_id:
          type: integer
        character_technique_id:
          type: integer
        technique_id:
          type: integer
      required:
      - character_technique_id
      - offer_id
      - technique_id
    Achievement:
      type: object
      description: Full serializer for achievement detail view.
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          readOnly: true
          description: Display name of the achievement
        slug:
          type: string
          readOnly: true
          description: URL-safe identifier for the achievement
          pattern: ^[-a-zA-Z0-9_]+$
        description:
          type: string
          readOnly: true
          description: What this achievement represents and how to earn it
        icon:
          type: string
          readOnly: true
          description: Icon identifier for frontend display
        notification_level:
          allOf:
          - $ref: '#/components/schemas/NotificationLevelEnum'
          readOnly: true
          description: |-
            Who gets notified when this achievement is earned

            * `personal` - Personal
            * `room` - Room
            * `gamewide` - Gamewide
        discovery:
          allOf:
          - $ref: '#/components/schemas/Discovery'
          readOnly: true
          nullable: true
        rewards:
          type: array
          items:
            $ref: '#/components/schemas/AchievementReward'
          readOnly: true
      required:
      - description
      - discovery
      - icon
      - id
      - name
      - notification_level
      - rewards
      - slug
    AchievementList:
      type: object
      description: Lightweight serializer for achievement list view.
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          readOnly: true
          description: Display name of the achievement
        slug:
          type: string
          readOnly: true
          description: URL-safe identifier for the achievement
          pattern: ^[-a-zA-Z0-9_]+$
        icon:
          type: string
          readOnly: true
          description: Icon identifier for frontend display
        notification_level:
          allOf:
          - $ref: '#/components/schemas/NotificationLevelEnum'
          readOnly: true
          description: |-
            Who gets notified when this achievement is earned

            * `personal` - Personal
            * `room` - Room
            * `gamewide` - Gamewide
      required:
      - icon
      - id
      - name
      - notification_level
      - slug
    AchievementReward:
      type: object
      description: Serializer for achievement rewards.
      properties:
        id:
          type: integer
          readOnly: true
        reward_type:
          type: string
          readOnly: true
        reward_key:
          type: string
          readOnly: true
        reward_name:
          type: string
          readOnly: true
        reward_value:
          type: string
          readOnly: true
          description: Additional value data for the reward (e.g., bonus amount)
      required:
      - id
      - reward_key
      - reward_name
      - reward_type
      - reward_value
    ActionCategoryEnum:
      enum:
      - physical
      - social
      - mental
      type: string
      description: |-
        * `physical` - Physical
        * `social` - Social
        * `mental` - Mental
    ActionPointPool:
      type: object
      description: The viewer's own AP pool — ``current`` is the spendable "remaining
        this week".
      properties:
        current:
          type: integer
        effective_maximum:
          type: integer
        banked:
          type: integer
      required:
      - banked
      - current
      - effective_maximum
    ActionRef:
      type: object
      description: |-
        Serializer for ActionRef frozen dataclass — the round-trippable dispatch reference.

        Uses a plain Serializer (not DataclassSerializer) to avoid drf_spectacular's
        get_type_hints() introspection, which cannot resolve TYPE_CHECKING-only imports
        (CheckType, ActionTemplate, ChallengeResolutionResult) in actions/types.py and
        crashes with NameError during schema generation.
      properties:
        backend:
          type: string
          readOnly: true
        challenge_instance_id:
          type: integer
          nullable: true
        approach_id:
          type: integer
          nullable: true
        technique_id:
          type: integer
          nullable: true
        registry_key:
          type: string
          nullable: true
        clash_id:
          type: integer
          nullable: true
        clash_action_slot:
          type: string
          nullable: true
        action_slot:
          type: string
          nullable: true
        position_id:
          type: integer
          nullable: true
        blueprint_id:
          type: integer
          nullable: true
        application_id:
          type: integer
          nullable: true
        target_object_id:
          type: integer
          nullable: true
      required:
      - backend
    ActionTemplateMinimal:
      type: object
      description: Minimal read-only representation of an ActionTemplate model instance.
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          readOnly: true
        default_delivery:
          type: string
          readOnly: true
      required:
      - default_delivery
      - id
      - name
    ActiveAlternateSelfResult:
      type: object
      description: Result of a successful shift or revert — the now-active alternate-self
        id.
      properties:
        active_alternate_self_id:
          type: integer
          nullable: true
      required:
      - active_alternate_self_id
    ActivePersonaResult:
      type: object
      description: 'Result of the #981 set-active-persona endpoint — the now-worn
        face id.'
      properties:
        active_persona_id:
          type: integer
          readOnly: true
      required:
      - active_persona_id
    AddOpponentRequest:
      type: object
      description: |-
        Write serializer for adding an opponent to an encounter.

        ``tier`` is required.  ``max_health`` is optional — when omitted the scaling
        formula fills every stat field automatically (Task 5 auto-fill mode).
        All other stat fields are optional overrides.

        ``position_id`` (#2005) is optional; when supplied it must name a Position
        in the encounter's own room — validated against the encounter's room here
        so a mismatched position never reaches the service layer.

        Expects ``encounter`` and ``request`` in serializer context (provided by the
        view) so that ``validate()`` can run the stakes gate.
      properties:
        name:
          type: string
          minLength: 1
          maxLength: 200
        tier:
          $ref: '#/components/schemas/Tier756Enum'
        max_health:
          type: integer
          minimum: 1
          nullable: true
        threat_pool_id:
          type: integer
        description:
          type: string
          minLength: 1
          default: ''
        soak_value:
          type: integer
          default: 0
        probing_threshold:
          type: integer
          nullable: true
        position_id:
          type: integer
          nullable: true
      required:
      - name
      - threat_pool_id
      - tier
    AggregateBeatContribution:
      type: object
      description: Read-only serializer for AggregateBeatContribution ledger rows.
      properties:
        id:
          type: integer
          readOnly: true
        beat:
          type: integer
          readOnly: true
        character_sheet:
          type: integer
          description: The character this sheet belongs to
          readOnly: true
        roster_entry:
          type: integer
          readOnly: true
          nullable: true
          description: Which roster tenure was active when this contribution was made.
            For audit only.
        points:
          type: integer
          readOnly: true
          description: Contribution points toward the beat's required_points threshold.
        era:
          type: integer
          readOnly: true
          nullable: true
        source_note:
          type: string
          readOnly: true
          description: Brief description of what produced this contribution (siege
            battle, mission, etc.).
        recorded_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - beat
      - character_sheet
      - era
      - id
      - points
      - recorded_at
      - roster_entry
      - source_note
    AlterationResolutionRequest:
      type: object
      description: Write serializer for resolving a PendingAlteration.
      properties:
        library_template_id:
          type: integer
          nullable: true
        name:
          type: string
          minLength: 3
          maxLength: 60
        player_description:
          type: string
          minLength: 1
        observer_description:
          type: string
          minLength: 1
        weakness_damage_type_id:
          type: integer
          nullable: true
        weakness_magnitude:
          type: integer
          minimum: 0
          default: 0
        resonance_bonus_magnitude:
          type: integer
          minimum: 0
          default: 0
        social_reactivity_magnitude:
          type: integer
          minimum: 0
          default: 0
        is_visible_at_rest:
          type: boolean
          default: false
        parent_template_id:
          type: integer
          nullable: true
    AlterationResolutionResponse:
      type: object
      description: Wire shape returned by the resolve action.
      properties:
        status:
          type: string
        event_id:
          type: integer
      required:
      - event_id
      - status
    AlternateSelf:
      type: object
      description: |-
        Read shape for the alternate-self switcher (#1111 slice 4).

        Includes the active alt-self flag for the played character so the switcher can
        highlight the currently-assumed form without a second round-trip.
      properties:
        id:
          type: integer
          readOnly: true
        display_name:
          type: string
          maxLength: 100
        persona_name:
          type: string
          nullable: true
          readOnly: true
        form_name:
          type: string
          nullable: true
          readOnly: true
        has_combat_profile:
          type: boolean
          readOnly: true
        has_techniques:
          type: boolean
          readOnly: true
        resonance_name:
          type: string
          nullable: true
          readOnly: true
        is_active:
          type: boolean
          readOnly: true
      required:
      - form_name
      - has_combat_profile
      - has_techniques
      - id
      - is_active
      - persona_name
      - resonance_name
    AlternateSelfRequest:
      type: object
      description: |-
        Read shape for the alternate-self switcher (#1111 slice 4).

        Includes the active alt-self flag for the played character so the switcher can
        highlight the currently-assumed form without a second round-trip.
      properties:
        display_name:
          type: string
          maxLength: 100
    AnchorOption:
      type: object
      description: Read-only representation of one eligible bonded fury anchor (#1543).
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          readOnly: true
        provocation_cap:
          type: integer
          readOnly: true
      required:
      - id
      - name
      - provocation_cap
    ApplicablePullsRequestRequest:
      type: object
      description: |-
        Request serializer for POST /api/magic/applicable-pulls/.

        ``character_sheet_id`` is required and must identify a CharacterSheet the
        requesting account owns (staff may pass any sheet). All other fields are
        optional context that narrows which threads are applicable.
      properties:
        character_sheet_id:
          type: integer
        technique_id:
          type: integer
          nullable: true
        effect_type_id:
          type: integer
          nullable: true
        target_persona_id:
          type: integer
          nullable: true
        scene_id:
          type: integer
          nullable: true
      required:
      - character_sheet_id
    ArcScopeEnum:
      enum:
      - global
      - org
      - giver
      type: string
      description: |-
        * `global` - Global
        * `org` - Organization
        * `giver` - Giver
    ArcanaTypeEnum:
      enum:
      - major
      - minor
      type: string
      description: |-
        * `major` - Major Arcana
        * `minor` - Minor Arcana
    ArchitecturalStyle:
      type: object
      description: |-
        An authorable architectural style for the builder picker (#1882).

        The player-facing lore lives in the linked ``CodexSubject`` — knowing that
        subject is what gates throwback styles (``can_build_style``). The description
        is surfaced inline here so the picker needn't hit the Codex app.
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          maxLength: 100
        description:
          type: string
          nullable: true
        is_default:
          type: boolean
          description: 'Default-available (living-realm tier). Non-default styles
            are the discoverable throwback tier (#1469): buildable only once the persona''s
            character KNOWS an entry under codex_subject (research-unlocked).'
        prestige_bonus:
          type: integer
          maximum: 2147483647
          minimum: 0
          description: Base dwelling-prestige addend for a building wearing this style
            (#1469 throwback tier). PLACEHOLDER magnitudes pending the tuning pass.
        cost_multiplier:
          type: string
          format: decimal
          pattern: ^-?\d{0,2}(?:\.\d{0,3})?$
          description: Construction/renovation cost knob for this style (#1469). Data
            only for now — charging awaits the economy pass (Phase E cost deduction
            is unwired).
      required:
      - description
      - id
      - name
    AreaList:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          readOnly: true
        level:
          allOf:
          - $ref: '#/components/schemas/LevelC97Enum'
          readOnly: true
        level_display:
          type: string
          readOnly: true
        children_count:
          type: integer
          readOnly: true
        grid_x:
          type: integer
          readOnly: true
          nullable: true
          description: Position within the PARENT area's local grid (rendering/hint
            data only — never routing); units are parent-local cells, meaningful only
            among siblings.
        grid_y:
          type: integer
          readOnly: true
          nullable: true
          description: Position within the PARENT area's local grid (rendering/hint
            data only — never routing); units are parent-local cells, meaningful only
            among siblings.
      required:
      - children_count
      - grid_x
      - grid_y
      - id
      - level
      - level_display
      - name
    AreaRoom:
      type: object
      properties:
        id:
          type: integer
        name:
          type: string
        area_name:
          type: string
          default: ''
      required:
      - id
      - name
    Aspect:
      type: object
      description: Serializer for Aspect model.
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          description: Aspect name (e.g., 'Warfare', 'Subterfuge')
          maxLength: 50
        description:
          type: string
          description: Description of what this aspect represents
      required:
      - id
      - name
    AssignMemberRequestRequest:
      type: object
      description: Request body for POST /api/covenants/ranks/{pk}/assign-member/.
      properties:
        membership:
          type: integer
          description: PK of the CharacterCovenantRole to assign to this rank.
      required:
      - membership
    AssistantGMClaim:
      type: object
      description: Read-only serializer for AssistantGMClaim records.
      properties:
        id:
          type: integer
          readOnly: true
        beat:
          type: integer
          readOnly: true
        assistant_gm:
          type: integer
          readOnly: true
        status:
          allOf:
          - $ref: '#/components/schemas/AssistantGMClaimStatusEnum'
          readOnly: true
          default: requested
        approved_by:
          type: integer
          readOnly: true
          nullable: true
          description: The Lead GM or Staff member who approved/rejected.
        rejection_note:
          type: string
          readOnly: true
          description: Reason for rejection (shown to AGM).
        framing_note:
          type: string
          readOnly: true
          description: Lead GM's one-paragraph framing for the AGM session. Sets the
            scene without exposing the rest of the story.
        requested_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - approved_by
      - assistant_gm
      - beat
      - framing_note
      - id
      - rejection_note
      - requested_at
      - status
      - updated_at
    AssistantGMClaimStatusEnum:
      enum:
      - requested
      - approved
      - rejected
      - cancelled
      - completed
      type: string
      description: |-
        * `requested` - Requested
        * `approved` - Approved
        * `rejected` - Rejected
        * `cancelled` - Cancelled
        * `completed` - Completed
    AudereMajoraCrossingResult:
      type: object
      description: Read serializer for AudereMajoraCrossingResult dataclass.
      properties:
        accepted:
          type: boolean
        level_before:
          type: integer
        level_after:
          type: integer
        chosen_path_name:
          type: string
        advisory_text:
          type: string
        declaration_interaction_id:
          type: integer
          nullable: true
      required:
      - accepted
      - advisory_text
      - chosen_path_name
      - declaration_interaction_id
      - level_after
      - level_before
    AudereMajoraRespondRequest:
      type: object
      description: Write serializer for the player's Crossing decision. accept=false
        declines.
      properties:
        offer_id:
          type: integer
        accept:
          type: boolean
        path_id:
          type: integer
          nullable: true
        declaration_text:
          type: string
          maxLength: 4000
      required:
      - accept
      - offer_id
    AudereOfferResult:
      type: object
      description: Read serializer for AudereOfferResult (audere.py dataclass).
      properties:
        accepted:
          type: boolean
        intensity_bonus_applied:
          type: integer
        anima_pool_expanded_by:
          type: integer
        advisory_text:
          type: string
      required:
      - accepted
      - advisory_text
      - anima_pool_expanded_by
      - intensity_bonus_applied
    AudereRespondRequest:
      type: object
      description: Write serializer for the player's Audere decision. accept=false
        declines.
      properties:
        offer_id:
          type: integer
        accept:
          type: boolean
      required:
      - accept
      - offer_id
    AvailableEnhancement:
      type: object
      description: Read-only serializer for AvailableEnhancement (technique enhancement
        option).
      properties:
        technique_id:
          type: integer
          readOnly: true
        technique_name:
          type: string
          readOnly: true
        effective_cost:
          type: integer
          readOnly: true
        soulfray_warning:
          allOf:
          - $ref: '#/components/schemas/SoulfrayWarning'
          readOnly: true
          nullable: true
      required:
      - effective_cost
      - soulfray_warning
      - technique_id
      - technique_name
    AxisEnum:
      enum:
      - TONE
      - CONSEQUENCE
      - WITNESS
      - SENSORY
      - TRIGGER
      type: string
      description: |-
        * `TONE` - Tone
        * `CONSEQUENCE` - Consequence
        * `WITNESS` - Witness & Secrecy
        * `SENSORY` - Sensory & Discovery
        * `TRIGGER` - Trigger
    BattleBindingEnum:
      enum:
      - standing
      - campaign
      type: string
      description: |-
        * `standing` - Standing (unit or banner — can rise again)
        * `campaign` - Campaign (one-time event — dissolves when done)
    BattleDetail:
      type: object
      description: Full battle aggregate — sides, places, units, and participants.
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          maxLength: 120
        outcome:
          $ref: '#/components/schemas/Outcome5d6Enum'
        risk_level:
          allOf:
          - $ref: '#/components/schemas/RiskLevelEnum'
          description: |-
            Stakes axis for companion death-gating (#1873). EXTREME/LETHAL make companion death possible on defeat. Mirrors CombatEncounter.risk_level.

            * `low` - Low
            * `moderate` - Moderate
            * `high` - High
            * `extreme` - Extreme
            * `lethal` - Lethal
        is_paused:
          type: boolean
          description: Set when a participant disconnects (#1899) — see maybe_pause_battle_for_disconnect.
        round:
          type: object
          additionalProperties: {}
          nullable: true
          description: The battle's current (latest non-completed) round, or None.
          readOnly: true
        sides:
          type: array
          items:
            $ref: '#/components/schemas/BattleSide'
          readOnly: true
        places:
          type: array
          items:
            $ref: '#/components/schemas/BattlePlace'
          readOnly: true
        units:
          type: array
          items:
            $ref: '#/components/schemas/BattleUnit'
          readOnly: true
        participants:
          type: array
          items:
            $ref: '#/components/schemas/BattleParticipant'
          readOnly: true
        concluded_at:
          type: string
          format: date-time
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        campaign_story_id:
          type: integer
          readOnly: true
          nullable: true
        scene_id:
          type: integer
          readOnly: true
        deeds:
          type: array
          items: {}
          description: |-
            Legendary deeds scoped to this battle's backing scene (#1735).

            Reads from the ``cached_deeds`` to_attr the view's Prefetch populates
            on the battle's Scene (world/battles/views.py) — never a fresh query.
          readOnly: true
      required:
      - campaign_story_id
      - concluded_at
      - created_at
      - deeds
      - id
      - name
      - participants
      - places
      - round
      - scene_id
      - sides
      - units
    BattleList:
      type: object
      description: Slim row for the battle list endpoint.
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          maxLength: 120
        scene_id:
          type: integer
          readOnly: true
        outcome:
          $ref: '#/components/schemas/Outcome5d6Enum'
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - created_at
      - id
      - name
      - scene_id
    BattleMapBlueprint:
      type: object
      description: Admin-authored, reusable battle-map layout a GM stages a Battle
        from (#2010).
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          maxLength: 100
        description:
          type: string
        is_active:
          type: boolean
          description: Inactive blueprints are hidden from the GM staging catalog
            but not deleted — existing data derived from them may still exist.
        places:
          type: array
          items:
            $ref: '#/components/schemas/BlueprintBattlePlace'
          readOnly: true
      required:
      - id
      - name
      - places
    BattleParticipant:
      type: object
      description: A player character enlisted in the battle, with their public persona
        face.
      properties:
        id:
          type: integer
          readOnly: true
        status:
          $ref: '#/components/schemas/BattleParticipantStatusEnum'
        side_id:
          type: integer
          readOnly: true
        place_id:
          type: integer
          readOnly: true
          nullable: true
        persona:
          type: object
          additionalProperties: {}
          nullable: true
          description: |-
            Public persona identity only — id/name/thumbnail(s), never account/username.

            ``thumbnail_media_url`` mirrors ``world/combat/serializers.py``'s
            ``get_thumbnail_media_url`` — the uploaded-portrait ``Media`` FK,
            already ``select_related``'d by the view's Prefetch (world/battles/views.py),
            so this never issues a query. ``thumbnail_url`` is the legacy URLField,
            kept alongside for callers still on it.
          readOnly: true
      required:
      - id
      - persona
      - place_id
      - side_id
    BattleParticipantStatusEnum:
      enum:
      - active
      - withdrawn
      - incapacitated
      type: string
      description: |-
        * `active` - Active
        * `withdrawn` - Withdrawn
        * `incapacitated` - Incapacitated
    BattlePlace:
      type: object
      description: A named front/zone, with its battle-map position and embedded structures.
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          maxLength: 120
        terrain_type:
          $ref: '#/components/schemas/TerrainTypeEnum'
        movement_cost:
          type: integer
          maximum: 32767
          minimum: 0
          description: 'Authored cost for a future reposition/movement action — not
            yet filed as an issue; #1712 explicitly did not build this. Data only.'
        x:
          type: number
          format: double
        y:
          type: number
          format: double
        footprint_radius:
          type: number
          format: double
        controlled_by_id:
          type: integer
          readOnly: true
          nullable: true
        encounter_scene_id:
          type: integer
          nullable: true
          description: The scene backing this front's bridged CombatEncounter, if
            any (#1236).
          readOnly: true
        encounter_roster:
          type: object
          additionalProperties: {}
          nullable: true
          description: |-
            Compact front-fight roster: status/outcome/participants/opponents (#2008).

            None when no CombatEncounter is bound. One query each for participants
            and opponents per bound place — battles carry a small, bounded number of
            fronts, so this is not an unbounded-loop N+1.
          readOnly: true
        vehicle:
          type: object
          additionalProperties: {}
          nullable: true
          description: |-
            Read the embedded vehicle, if any, through the battle's state cache.

            Never a fresh query — ``BattleStateCache.vehicle_at_place`` is the
            single source of truth for which vehicle occupies a place (#1714).
          readOnly: true
        fortifications:
          type: array
          items:
            $ref: '#/components/schemas/Fortification'
          readOnly: true
      required:
      - controlled_by_id
      - encounter_roster
      - encounter_scene_id
      - footprint_radius
      - fortifications
      - id
      - name
      - vehicle
      - x
      - y
    BattleSide:
      type: object
      description: One side in the battle, with its victory tally and fielding covenant.
      properties:
        id:
          type: integer
          readOnly: true
        role:
          $ref: '#/components/schemas/RoleEnum'
        victory_points:
          type: integer
          maximum: 2147483647
          minimum: 0
        victory_threshold:
          type: integer
          maximum: 2147483647
          minimum: 0
        posture:
          $ref: '#/components/schemas/PostureEnum'
        covenant_id:
          type: integer
          readOnly: true
          nullable: true
        covenant_name:
          type: string
          nullable: true
          readOnly: true
      required:
      - covenant_id
      - covenant_name
      - id
    BattleUnit:
      type: object
      description: An abstract typed force at a particular front (or embedded in a
        vehicle).
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          readOnly: true
        descriptor:
          type: string
          readOnly: true
        quality:
          type: string
          readOnly: true
        status:
          $ref: '#/components/schemas/BattleUnitStatusEnum'
        strength:
          type: integer
          readOnly: true
        morale:
          type: integer
          readOnly: true
        individual_count:
          type: string
          readOnly: true
        side_id:
          type: integer
          readOnly: true
        place_id:
          type: integer
          readOnly: true
          nullable: true
      required:
      - descriptor
      - id
      - individual_count
      - morale
      - name
      - place_id
      - quality
      - side_id
      - strength
    BattleUnitStatusEnum:
      enum:
      - active
      - routed
      - destroyed
      type: string
      description: |-
        * `active` - Active
        * `routed` - Routed
        * `destroyed` - Destroyed
    BattleUnitTemplate:
      type: object
      description: Admin-authored, reusable unit stat block a GM stages a Battle from
        (#2010).
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          maxLength: 100
        descriptor:
          type: string
          maxLength: 200
        quality:
          $ref: '#/components/schemas/QualityEnum'
        strength:
          type: integer
          maximum: 2147483647
          minimum: 0
        morale:
          type: integer
          maximum: 2147483647
          minimum: 0
        individual_count:
          type: integer
          maximum: 2147483647
          minimum: 0
          nullable: true
          description: Population data point mirroring BattleUnit.individual_count
            — null means 'not a swarm-style unit'.
        is_active:
          type: boolean
          description: Inactive templates are hidden from the GM staging catalog but
            not deleted.
        properties:
          type: array
          items:
            $ref: '#/components/schemas/BattleUnitTemplateProperty'
          readOnly: true
        capability_values:
          type: array
          items:
            $ref: '#/components/schemas/BattleUnitTemplateCapability'
          readOnly: true
      required:
      - capability_values
      - id
      - name
      - properties
    BattleUnitTemplateCapability:
      type: object
      description: An authored (template, capability) -> magnitude row, with the capability's
        name.
      properties:
        capability_id:
          type: integer
          readOnly: true
        capability_name:
          type: string
          readOnly: true
        value:
          type: integer
          maximum: 2147483647
          minimum: -2147483648
      required:
      - capability_id
      - capability_name
    BattleUnitTemplateProperty:
      type: object
      description: A Property tag on a BattleUnitTemplate, by name -- never a bare
        id (#2010).
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          maxLength: 100
      required:
      - id
      - name
    Beat:
      type: object
      description: Full serializer for Beat including all Phase 2 predicate config
        fields.
      properties:
        id:
          type: integer
          readOnly: true
        episode:
          type: integer
        episode_title:
          type: string
          readOnly: true
        chapter_title:
          type: string
          readOnly: true
        story_id:
          type: integer
          readOnly: true
        story_title:
          type: string
          readOnly: true
        predicate_type:
          allOf:
          - $ref: '#/components/schemas/PredicateTypeEnum'
          default: gm_marked
        outcome:
          allOf:
          - $ref: '#/components/schemas/OutcomeD50Enum'
          description: |-
            The story's current outcome on this beat — a single shared value across the story's progression (the owning character for CHARACTER scope, the group for GROUP scope, the world for GLOBAL scope). A story has exactly one progression trail, so this field represents the whole story's state, not per-character state. Historical per-character contributions live in BeatCompletion.

            * `unsatisfied` - Unsatisfied
            * `success` - Success
            * `failure` - Failure
            * `expired` - Expired
            * `pending_gm_review` - Pending GM review
        visibility:
          $ref: '#/components/schemas/BeatVisibilityEnum'
        internal_description:
          type: string
          description: 'Author/Lead GM/staff view: real predicate + meaning.'
        player_hint:
          type: string
          description: Shown while active (if visibility=HINTED or VISIBLE).
        player_resolution_text:
          type: string
          description: Shown in story log after beat completes.
        order:
          type: integer
          maximum: 2147483647
          minimum: 0
        kind:
          $ref: '#/components/schemas/BeatKindEnum'
        advances:
          type: boolean
          description: 'False = Tangent: recorded for history, never gates a transition.'
        risk:
          allOf:
          - $ref: '#/components/schemas/RiskEnum'
          description: |-
            Stakes declaration — how life-threatening/consequential this beat is. Drives Legend award magnitude on SUCCESS (see world.societies.constants.RISK_LEGEND_AWARDS). Authoring trust-gated in the serializer.

            * `none` - None
            * `low` - Low
            * `moderate` - Moderate
            * `high` - High
            * `extreme` - Extreme
        target_level:
          type: integer
          maximum: 32767
          minimum: 0
          nullable: true
          description: The character level this beat's stakes are declared against
            ('EXTREME at level 4'). Effective risk at activation is computed from
            the gap between this and the actual party's average level. Required (via
            readiness validation, not clean()) when risk != NONE.
        required_level:
          type: integer
          maximum: 2147483647
          minimum: 0
          nullable: true
          description: For CHARACTER_LEVEL_AT_LEAST predicates.
        required_achievement:
          type: integer
          nullable: true
          description: For ACHIEVEMENT_HELD predicates.
        required_condition_template:
          type: integer
          nullable: true
          description: For CONDITION_HELD predicates.
        required_codex_entry:
          type: integer
          nullable: true
          description: For CODEX_ENTRY_UNLOCKED predicates.
        referenced_story:
          type: integer
          nullable: true
          description: For STORY_AT_MILESTONE predicates.
        referenced_milestone_type:
          description: |-
            Which kind of milestone to check on referenced_story.

            * `story_resolved` - Story resolved
            * `chapter_reached` - Chapter reached or passed
            * `episode_reached` - Episode reached or passed
          oneOf:
          - $ref: '#/components/schemas/ReferencedMilestoneTypeEnum'
          - $ref: '#/components/schemas/BlankEnum'
        referenced_chapter:
          type: integer
          nullable: true
          description: For referenced_milestone_type=CHAPTER_REACHED.
        referenced_episode:
          type: integer
          nullable: true
          description: For referenced_milestone_type=EPISODE_REACHED.
        required_points:
          type: integer
          maximum: 2147483647
          minimum: 0
          nullable: true
          description: For AGGREGATE_THRESHOLD predicates — total contribution points
            required.
        required_society:
          type: integer
          nullable: true
          description: For FACTION_STANDING_AT_LEAST predicates (society-level).
        required_organization:
          type: integer
          nullable: true
          description: For FACTION_STANDING_AT_LEAST predicates (organization-level).
        required_standing:
          type: integer
          maximum: 2147483647
          minimum: -2147483648
          nullable: true
          description: For FACTION_STANDING_AT_LEAST predicates — minimum raw SocietyReputation/OrganizationReputation.value
            (-1000..1000).
        agm_eligible:
          type: boolean
          description: Lead GM may flag this beat to be claimable by Assistant GMs.
        deadline:
          type: string
          format: date-time
          nullable: true
          description: Optional wall-clock deadline. Expiry handling deferred to Phase
            3+.
        success_consequences:
          type: integer
          nullable: true
          description: ConsequencePool to fire when this beat resolves SUCCESS.
        failure_consequences:
          type: integer
          nullable: true
          description: ConsequencePool to fire when this beat resolves FAILURE.
        expired_consequences:
          type: integer
          nullable: true
          description: ConsequencePool to fire when this beat resolves EXPIRED.
        required_mission:
          type: integer
          nullable: true
          description: 'Optional: a MissionTemplate this beat requires (Phase 5b.3
            data shape only; engine deferred). SET_NULL on template delete.'
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
        can_mark:
          type: boolean
          description: |-
            Return True if the requesting user may mark this beat.

            Delegates to CanMarkBeat.has_object_permission.  The view arg is
            passed as None — CanMarkBeat does not use it.

            Requires the Beat queryset to select_related
            'episode__chapter__story__primary_table' to avoid N+1 on list endpoints.
            BeatViewSet.queryset already includes this chain.
          readOnly: true
      required:
      - can_mark
      - chapter_title
      - created_at
      - episode
      - episode_title
      - id
      - internal_description
      - story_id
      - story_title
      - updated_at
    BeatKindEnum:
      enum:
      - situation
