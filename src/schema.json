    Cantrip:
      type: object
      description: |-
        Serializer for Cantrip lookup records with allowed facets.

        Mechanical fields (intensity, control, anima cost) are intentionally
        hidden — the player only sees name, description, archetype, and facets.
        style_id is exposed for path-based filtering.
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          readOnly: true
        description:
          type: string
          readOnly: true
        archetype:
          allOf:
          - $ref: '#/components/schemas/CantripArchetypeEnum'
          readOnly: true
          description: |-
            Player-facing category for CG grouping: attack, defense, buff, debuff, utility.

            * `attack` - Attack
            * `defense` - Defense
            * `buff` - Buff
            * `debuff` - Debuff
            * `utility` - Utility
        requires_facet:
          type: boolean
          readOnly: true
          description: If true, player must pick a facet (element/damage type) from
            allowed_facets.
        facet_prompt:
          type: string
          readOnly: true
          description: Player-facing dropdown label, e.g. "Choose your element". Only
            used when requires_facet=True.
        allowed_facets:
          type: array
          items:
            type: object
            additionalProperties: {}
          description: Get allowed facets using cached property.
          readOnly: true
        sort_order:
          type: integer
          readOnly: true
        style_id:
          type: integer
          readOnly: true
      required:
      - allowed_facets
      - archetype
      - description
      - facet_prompt
      - id
      - name
      - requires_facet
      - sort_order
      - style_id
