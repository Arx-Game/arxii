      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this GM Table.
        required: true
      tags:
      - gm
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/GMTableRequest'
        required: true
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GMTable'
          description: ''
