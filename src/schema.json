    DramaticMomentSuggestion:
      type: object
      description: |-
        Read-only GM confirm/dismiss inbox row (#2183).

        List/confirm/dismiss all render this shape; there is no client-writable field —
        resolution (confirm/dismiss) happens exclusively through the viewset's dispatch
        of the REGISTRY actions, never through a serializer ``create``/``update``.
      properties:
        id:
          type: integer
          readOnly: true
        moment_type:
          type: integer
          readOnly: true
        moment_type_label:
          type: string
          readOnly: true
        character_sheet:
          type: integer
          description: The character this sheet belongs to
          readOnly: true
        scene:
          type: integer
          readOnly: true
          nullable: true
          description: Scene context; nullable for resilience to scene cleanup.
        interaction:
          type: integer
          readOnly: true
          nullable: true
          description: The entrance pose that triggered this suggestion; nullable.
        success_level:
          type: integer
          readOnly: true
          description: Cast success level that triggered this suggestion.
        status:
          allOf:
          - $ref: '#/components/schemas/DramaticMomentSuggestionStatusEnum'
          readOnly: true
          default: pending
        resolved_by:
          type: integer
          readOnly: true
          nullable: true
          description: GM account that confirmed or dismissed this suggestion.
        confirmed_tag:
          type: integer
          readOnly: true
          nullable: true
          description: The DramaticMomentTag minted on confirmation, if any.
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - character_sheet
      - confirmed_tag
      - created_at
      - id
      - interaction
      - moment_type
      - moment_type_label
      - resolved_by
      - scene
      - status
      - success_level
    DramaticMomentSuggestionStatusEnum:
      enum:
      - pending
      - confirmed
      - dismissed
      type: string
      description: |-
        * `pending` - Pending
        * `confirmed` - Confirmed
        * `dismissed` - Dismissed
    DramaticMomentTag:
      type: object
      description: |-
        Create + read dramatic-moment tags (#1139).

        Write: accepts ``moment_type`` plus EITHER ``interaction`` (pose) — from which
        ``character_sheet`` and ``scene`` are derived — OR explicit ``character_sheet`` + ``scene``.
        ``tagged_by`` is injected from the requesting account in the view; never client-supplied.
      properties:
        id:
          type: integer
          readOnly: true
        moment_type:
          type: integer
        character_sheet:
          type: integer
          description: The character this sheet belongs to
        scene:
          type: integer
          nullable: true
          description: Scene context; nullable for resilience to scene cleanup.
        interaction:
          type: integer
          nullable: true
          description: The pose that earned this moment; nullable for non-pose tags.
        tagged_by:
          type: integer
          readOnly: true
          description: Account that tagged this moment. PROTECT because provenance
            must be kept.
        tagged_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - id
      - moment_type
      - tagged_at
      - tagged_by
    DramaticMomentTagRequest:
      type: object
      description: |-
        Create + read dramatic-moment tags (#1139).

        Write: accepts ``moment_type`` plus EITHER ``interaction`` (pose) — from which
        ``character_sheet`` and ``scene`` are derived — OR explicit ``character_sheet`` + ``scene``.
        ``tagged_by`` is injected from the requesting account in the view; never client-supplied.
      properties:
        moment_type:
          type: integer
        character_sheet:
          type: integer
          description: The character this sheet belongs to
        scene:
          type: integer
          nullable: true
          description: Scene context; nullable for resilience to scene cleanup.
        interaction:
          type: integer
          nullable: true
          description: The pose that earned this moment; nullable for non-pose tags.
      required:
      - moment_type
    DramaticMomentType:
      type: object
      description: Read-only catalog of authored dramatic-moment types (for the tag
        picker).
      properties:
        id:
          type: integer
          readOnly: true
        label:
          type: string
          description: Display name used as the renown deed title (e.g. 'Grand Entrance').
          maxLength: 100
        description:
          type: string
        resonance:
          type: integer
          description: Resonance granted when this moment type is tagged.
        resonance_amount:
          type: integer
          maximum: 2147483647
          minimum: 0
          description: Flat resonance units granted to the tagged character.
        per_scene_cap:
          type: integer
          maximum: 2147483647
          minimum: 0
          description: Maximum number of times this moment type may be awarded to
            a given character within a single scene.
      required:
      - id
      - label
      - resonance
