          nullable: true
          description: The ENTRY pose being endorsed; nullable for resilience to interaction
            cleanup.
        resonance:
          type: integer
        persona_snapshot:
          type: integer
          readOnly: true
          nullable: true
        granted_amount:
          type: integer
          readOnly: true
          description: Captured from config at creation.
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - created_at
      - endorsee_sheet
      - endorser_sheet
      - entry_interaction
      - granted_amount
