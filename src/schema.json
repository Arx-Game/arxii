        offer_label:
          type: string
          readOnly: true
        role_name:
          type: string
          readOnly: true
        target_persona:
          type: integer
          description: The persona this summons is directed at.
        message:
          type: string
          description: IC text — what the servant learns of the master's wish.
        status:
          allOf:
          - $ref: '#/components/schemas/OfferSummonsStatusEnum'
          readOnly: true
          default: pending
          description: |-
            Lifecycle state of this summons.

            * `pending` - Pending
            * `accepted` - Accepted
            * `declined` - Declined
            * `expired` - Expired
        expires_at:
          type: string
          format: date-time
          nullable: true
          description: When this summons lapses if unanswered. Null = no expiry.
        created_by:
          type: integer
          nullable: true
          description: The GM who created this summons. Null for staff-created.
        created_at:
          type: string
          format: date-time
          readOnly: true
        resolved_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
          description: When the summons was accepted, declined, or expired.
      required:
      - created_at
      - id
      - offer
      - offer_label
      - resolved_at
      - role_name
      - status
      - target_persona
    OfferSummonsCreateRequest:
      type: object
