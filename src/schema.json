        schema:
          type: integer
      - name: page_size
        required: false
        in: query
        description: Number of results to return per page.
        schema:
          type: integer
      - in: query
        name: status
        schema:
          type: string
          enum:
          - dismissed
          - open
          - reviewed
        description: |-
          * `open` - Open
          * `reviewed` - Reviewed
          * `dismissed` - Dismissed
      tags:
      - player-submissions
      security:
      - cookieAuth: []
