        outfit:
          type: integer
          readOnly: true
        item_instance:
          allOf:
          - $ref: '#/components/schemas/ItemInstanceRead'
          readOnly: true
        body_region:
          allOf:
          - $ref: '#/components/schemas/BodyRegionEnum'
          readOnly: true
        equipment_layer:
          allOf:
          - $ref: '#/components/schemas/EquipmentLayerEnum'
          readOnly: true
      required:
      - body_region
      - equipment_layer
      - id
      - item_instance
      - outfit
    OutfitSlotWriteRequest:
      type: object
      description: Write serializer for OutfitSlot — delegates to add_outfit_slot
        service.
      properties:
        outfit:
          type: integer
        item_instance:
          type: integer
        body_region:
          $ref: '#/components/schemas/BodyRegionEnum'
        equipment_layer:
          $ref: '#/components/schemas/EquipmentLayerEnum'
      required:
      - body_region
      - equipment_layer
      - item_instance
      - outfit
    OutfitWriteRequest:
      type: object
      description: Write serializer for Outfit — POST snapshots current loadout via
        save_outfit.
      properties:
        name:
          type: string
          minLength: 1
          maxLength: 100
        description:
          type: string
        character_sheet:
          type: integer
          description: The character this sheet belongs to
        wardrobe:
          type: integer
          description: The wardrobe ItemInstance this outfit is stored in.
      required:
      - character_sheet
      - name
      - wardrobe
    OwnerModeEnum:
      enum:
      - PERSONAL
      - COVENANT
      type: string
      description: |-
        * `PERSONAL` - Personal (Persona-owned home)
        * `COVENANT` - Covenant (Organization-owned sacred ground)
    PaceModeEnum:
      enum:
      - timed
      - ready
      - manual
      type: string
      description: |-
        * `timed` - Timed
        * `ready` - Ready
        * `manual` - Manual
