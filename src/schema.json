        category:
          type: string
          readOnly: true
        codex_entry_id:
          type: integer
          readOnly: true
          nullable: true
        is_signature:
          type: boolean
          description: True when this technique came from the tradition's signature
            set.
          readOnly: true
      required:
      - category
      - codex_entry_id
      - description
      - id
      - is_signature
      - name
