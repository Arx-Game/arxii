    Thread:
      type: object
      description: |-
        Serializer for Thread records (Spec A §4.5).

        Read: returns level / developed_points / resonance detail for display.
        Write: accepts target_kind + target_id + resonance + character_sheet_id to
        weave a new thread; target_id is resolved to the typed FK via ``create``
        which delegates to ``weave_thread``. ``character_sheet_id`` must identify
        a CharacterSheet on an active roster tenure belonging to the requesting
        account (staff may pass any sheet).

        Read-only computed fields (SerializerMethodFields):
        - path_cap: the path-side cap (compute_path_cap)
        - anchor_cap: the anchor-side cap (compute_anchor_cap); null for ROOM threads
          (AnchorCapNotImplemented is not yet spec'd)
        - effective_cap: min(path_cap, anchor_cap); null when anchor_cap is null
      properties:
        id:
          type: integer
          readOnly: true
        owner:
          type: integer
          description: Character who owns this thread.
          readOnly: true
        resonance:
          type: integer
          description: Resonance this thread channels.
        resonance_name:
          type: string
          readOnly: true
        target_kind:
          allOf:
          - $ref: '#/components/schemas/TargetKindEnum'
          description: |-
            Discriminator selecting which target_* FK is populated.

            * `TRAIT` - Trait
            * `TECHNIQUE` - Technique
            * `FACET` - Facet
            * `ROOM` - Room
            * `RELATIONSHIP_TRACK` - Relationship Track
            * `RELATIONSHIP_CAPSTONE` - Relationship Capstone
            * `COVENANT_ROLE` - Covenant Role
            * `SANCTUM` - Sanctum
        name:
          type: string
          default: ''
        description:
          type: string
          default: ''
        level:
          type: integer
          readOnly: true
          description: Current level on the internal scale (multiples of 10).
        developed_points:
          type: integer
          readOnly: true
          description: Permanent points; advances level via ThreadLevelUnlock entries.
        path_cap:
          type: integer
          description: Return the path-side cap for this thread's owner.
          readOnly: true
        anchor_cap:
          type: integer
          nullable: true
          description: Return the anchor-side cap, or None for ROOM threads (not yet
            implemented).
          readOnly: true
        effective_cap:
          type: integer
          nullable: true
          description: Return min(path_cap, anchor_cap), or None when anchor_cap is
            unavailable.
          readOnly: true
        retired_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
          description: Set when owner soft-retires this thread; retired threads are
            excluded from list/detail views and from all pull / passive paths.
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - anchor_cap
      - created_at
      - developed_points
      - effective_cap
      - id
      - level
      - owner
      - path_cap
      - resonance
      - resonance_name
      - retired_at
      - target_kind
      - updated_at
    ThreadApplicability:
      type: object
      description: |-
        One row in the applicable-pulls response.

        Response shape: ``{thread_id, applicable, inapplicable_reason}``.
        ``inapplicable_reason`` is null when ``applicable`` is true.
      properties:
        thread_id:
          type: integer
        applicable:
          type: boolean
        inapplicable_reason:
          type: string
          nullable: true
      required:
      - applicable
      - thread_id
