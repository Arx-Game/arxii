        participants:
          type: array
          items:
            $ref: '#/components/schemas/VoyageParticipant'
          readOnly: true
        started_at:
          type: string
          format: date-time
          readOnly: true
        completed_at:
          type: string
          format: date-time
          nullable: true
      required:
      - destination_name
      - id
      - leader_id
      - leader_name
      - origin_name
      - participants
      - started_at
      - travel_method_id
      - travel_method_name
    VoyageInvite:
      type: object
      description: Serializer for VoyageInvite — the RSVP invitation.
      properties:
        id:
          type: integer
          readOnly: true
        voyage_id:
          type: integer
          readOnly: true
        target_persona_id:
          type: integer
          readOnly: true
        target_persona_name:
          type: string
          readOnly: true
        invited_by_id:
          type: integer
          nullable: true
          readOnly: true
        invited_by_name:
          type: string
          readOnly: true
        response:
          $ref: '#/components/schemas/Response7baEnum'
        invited_at:
          type: string
          format: date-time
          readOnly: true
        responded_at:
          type: string
          format: date-time
          nullable: true
        voyage_destination:
          type: string
          readOnly: true
      required:
      - id
      - invited_at
      - invited_by_id
      - invited_by_name
      - target_persona_id
      - target_persona_name
      - voyage_destination
      - voyage_id
    VoyageParticipant:
      type: object
      description: Serializer for VoyageParticipant.
      properties:
        id:
          type: integer
          readOnly: true
        persona_id:
          type: integer
          readOnly: true
        persona_name:
          type: string
          readOnly: true
        joined_at:
          type: string
          format: date-time
          readOnly: true
        left_at:
          type: string
          format: date-time
          nullable: true
        legs_traveled:
          type: integer
          maximum: 32767
          minimum: 0
      required:
      - id
      - joined_at
      - persona_id
      - persona_name
    VoyageStatusEnum:
      enum:
      - DRAFT
      - IN_TRANSIT
      - ARRIVED
      - ABANDONED
      type: string
      description: |-
        * `DRAFT` - Draft
        * `IN_TRANSIT` - In Transit
        * `ARRIVED` - Arrived
        * `ABANDONED` - Abandoned
    WeeklyVote:
      type: object
      description: Read serializer for WeeklyVote instances.
      properties:
        id:
          type: integer
          readOnly: true
        target_type:
          $ref: '#/components/schemas/WeeklyVoteTargetTypeEnum'
        target_id:
          type: integer
          maximum: 2147483647
          minimum: 0
          description: PK of the voted-on object (not a FK -- no cascades)
        target_name:
          type: string
          description: Resolve a human-readable name for the vote target.
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - created_at
      - id
      - target_id
      - target_name
      - target_type
    WeeklyVoteRequest:
      type: object
      description: Read serializer for WeeklyVote instances.
      properties:
        target_type:
          $ref: '#/components/schemas/WeeklyVoteTargetTypeEnum'
        target_id:
          type: integer
          maximum: 2147483647
          minimum: 0
          description: PK of the voted-on object (not a FK -- no cascades)
      required:
      - target_id
      - target_type
    WeeklyVoteTargetTypeEnum:
      enum:
      - interaction
      - scene_participation
      - journal
      type: string
      description: |-
        * `interaction` - Interaction
        * `scene_participation` - Scene Participation
        * `journal` - Journal Entry
    Will:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        character_sheet:
          type: integer
          description: The character this sheet belongs to
        testament_text:
          type: string
          description: Player-authored prose an executor reads aloud at the will-reading.
        updated_at:
          type: string
          format: date-time
          readOnly: true
        bequests:
          type: array
          items:
            $ref: '#/components/schemas/Bequest'
          readOnly: true
        executors:
          type: array
          items:
            $ref: '#/components/schemas/WillExecutor'
          readOnly: true
        is_frozen:
          type: boolean
          readOnly: true
      required:
      - bequests
      - character_sheet
      - executors
      - id
      - is_frozen
      - updated_at
    WillExecutor:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        will:
          type: integer
        persona:
          type: integer
        persona_name:
          type: string
          readOnly: true
      required:
      - id
      - persona
      - persona_name
      - will
    WillExecutorRequest:
      type: object
      properties:
        will:
          type: integer
        persona:
          type: integer
      required:
      - persona
      - will
    WillRequest:
      type: object
      properties:
        character_sheet:
          type: integer
          description: The character this sheet belongs to
        testament_text:
          type: string
          description: Player-authored prose an executor reads aloud at the will-reading.
      required:
      - character_sheet
    WindowReactInput:
      type: object
      properties:
        persona_id:
          type: integer
          description: PK of the Persona reacting (must belong to the requester).
        choice:
          type: string
          description: Slug from the window's choices payload.
          maxLength: 64
      required:
      - choice
      - persona_id
    WindowReactInputRequest:
      type: object
      properties:
        persona_id:
          type: integer
          description: PK of the Persona reacting (must belong to the requester).
        choice:
          type: string
          minLength: 1
          description: Slug from the window's choices payload.
          maxLength: 64
      required:
      - choice
      - persona_id
    WorldBuilderArea:
      type: object
      description: |-
        Area-tree node for the staff world-builder canvas (#2449).

        Unlike ``AreaListSerializer`` (player-facing area browser), this exposes
        ``slug``/``origin``/``parent`` — staff-only bookkeeping fields the canvas
        needs to render the AUTHORED/STORY/PLAYER distinction and the fixture-key
        promotion flow.
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          readOnly: true
        slug:
          type: string
          readOnly: true
          nullable: true
          description: Permanent stable identifier for authored (exported) areas (#2448).
            Required when origin=AUTHORED; NULL for runtime areas.
          pattern: ^[-a-zA-Z0-9_]+$
        level:
          allOf:
          - $ref: '#/components/schemas/LevelC97Enum'
          readOnly: true
        level_display:
          type: string
          readOnly: true
        origin:
          allOf:
          - $ref: '#/components/schemas/OriginEnum'
          readOnly: true
          description: |-
            Who authored this area — only AUTHORED areas export (#2448).

            * `authored` - Authored (canonical, exported)
            * `story` - GM Story (never exported)
            * `player` - Player-built (never exported)
        parent:
          type: integer
          readOnly: true
          nullable: true
        children_count:
          type: integer
          readOnly: true
        grid_x:
          type: integer
          readOnly: true
          nullable: true
          description: Position within the PARENT area's local grid (rendering/hint
            data only — never routing); units are parent-local cells, meaningful only
            among siblings.
        grid_y:
          type: integer
          readOnly: true
          nullable: true
          description: Position within the PARENT area's local grid (rendering/hint
            data only — never routing); units are parent-local cells, meaningful only
            among siblings.
      required:
      - children_count
      - grid_x
      - grid_y
      - id
      - level
      - level_display
      - name
      - origin
      - parent
      - slug
    WorldBuilderAreaManager:
      type: object
      description: 'The full staff-only area-manager payload: area header + rooms
        + exits.'
      properties:
        area:
          $ref: '#/components/schemas/WorldBuilderArea'
        rooms:
          type: array
          items:
            $ref: '#/components/schemas/WorldBuilderRoom'
        exits:
          type: array
          items:
            $ref: '#/components/schemas/WorldBuilderExit'
      required:
      - area
      - exits
      - rooms
    WorldBuilderClueTrigger:
      type: object
      description: One ClueTrigger placement, nested in a WorldBuilderRoom payload
        (#2451).
      properties:
        id:
          type: integer
        clue_name:
          type: string
        clue_slug:
          type: string
        fixture_key:
          type: string
          nullable: true
      required:
      - clue_name
      - clue_slug
      - fixture_key
      - id
    WorldBuilderExit:
      type: object
      description: |-
        One directed exit in the staff area-manager payload (#2449).

        ``to_area_id`` is null when the destination has no RoomProfile (or no
        destination at all) — a cross-area exit is otherwise a normal row here,
        the canvas renders the far end as an edge-of-view marker.
      properties:
        id:
          type: integer
        name:
          type: string
        from_room_id:
          type: integer
        to_room_id:
          type: integer
          nullable: true
        to_room_name:
          type: string
          nullable: true
        to_area_id:
          type: integer
          nullable: true
      required:
      - from_room_id
      - id
      - name
      - to_area_id
      - to_room_id
      - to_room_name
    WorldBuilderPortalAnchor:
      type: object
      description: One active PortalAnchor, nested in a WorldBuilderRoom payload (#2451).
      properties:
        id:
          type: integer
        kind_name:
          type: string
        name:
          type: string
        fixture_key:
          type: string
          nullable: true
      required:
      - fixture_key
      - id
      - kind_name
      - name
    WorldBuilderRoom:
      type: object
      description: |-
        One RoomProfile in the staff area-manager payload (#2449).

        Unlike the owner-facing ``buildings.ManagerRoomSerializer``, this has no
        ownership gate (staff-only read) and includes private rooms plus
        staff-only bookkeeping (``fixture_key``, ``origin``, ``occupant_count``).
      properties:
        id:
          type: integer
        name:
          type: string
        description:
          type: string
        is_public:
          type: boolean
        is_social_hub:
          type: boolean
        is_outdoor:
          type: boolean
        enclosure:
          type: string
        size_name:
          type: string
          nullable: true
        grid_x:
          type: integer
          nullable: true
        grid_y:
          type: integer
          nullable: true
        floor:
          type: integer
        fixture_key:
          type: string
          nullable: true
        origin:
          type: string
        occupant_count:
          type: integer
        clues:
          type: array
          items:
            $ref: '#/components/schemas/WorldBuilderRoomClue'
        clue_triggers:
          type: array
          items:
            $ref: '#/components/schemas/WorldBuilderClueTrigger'
        portal_anchors:
          type: array
          items:
            $ref: '#/components/schemas/WorldBuilderPortalAnchor'
      required:
      - clue_triggers
      - clues
      - description
      - enclosure
      - fixture_key
      - floor
      - grid_x
      - grid_y
      - id
      - is_outdoor
      - is_public
      - is_social_hub
      - name
      - occupant_count
      - origin
      - portal_anchors
      - size_name
    WorldBuilderRoomClue:
      type: object
      description: One RoomClue placement, nested in a WorldBuilderRoom payload (#2451).
      properties:
        id:
          type: integer
        clue_name:
          type: string
        clue_slug:
          type: string
        detect_difficulty:
          type: integer
        fixture_key:
          type: string
          nullable: true
      required:
      - clue_name
      - clue_slug
      - detect_difficulty
      - fixture_key
      - id
    WorshippedBeingRef:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          maxLength: 100
        tradition_name:
          type: string
          readOnly: true
      required:
      - id
      - name
      - tradition_name
    WorshippedBeingRefRequest:
      type: object
      properties:
        name:
          type: string
          minLength: 1
          maxLength: 100
      required:
      - name
    WriteupComplaintWrite:
      type: object
      description: |-
        Validate input for the complaint endpoint.

        Same shape as WriteupKudosWriteSerializer plus a mandatory ``reason`` field.
        Permissions (visibility check) are enforced inside the action / service.
      properties:
        writeup_type:
          $ref: '#/components/schemas/WriteupTypeEnum'
        writeup_id:
          type: integer
        reason:
          type: string
      required:
      - reason
      - writeup_id
      - writeup_type
    WriteupComplaintWriteRequest:
      type: object
      description: |-
        Validate input for the complaint endpoint.

        Same shape as WriteupKudosWriteSerializer plus a mandatory ``reason`` field.
        Permissions (visibility check) are enforced inside the action / service.
      properties:
        writeup_type:
          $ref: '#/components/schemas/WriteupTypeEnum'
        writeup_id:
          type: integer
        reason:
          type: string
          minLength: 1
      required:
      - reason
      - writeup_id
      - writeup_type
    WriteupKudosWrite:
      type: object
      description: |-
        Validate input for the kudos endpoint.

        ``writeup_type`` selects which of the three writeup models the ID refers to.
        ``writeup_id`` is the pk of that writeup. Existence is validated inside the
        action (raises WriteupFeedbackError → mapped to a 400 response body).
      properties:
        writeup_type:
          $ref: '#/components/schemas/WriteupTypeEnum'
        writeup_id:
          type: integer
      required:
      - writeup_id
      - writeup_type
    WriteupKudosWriteRequest:
      type: object
      description: |-
        Validate input for the kudos endpoint.

        ``writeup_type`` selects which of the three writeup models the ID refers to.
        ``writeup_id`` is the pk of that writeup. Existence is validated inside the
        action (raises WriteupFeedbackError → mapped to a 400 response body).
      properties:
        writeup_type:
          $ref: '#/components/schemas/WriteupTypeEnum'
        writeup_id:
          type: integer
      required:
      - writeup_id
      - writeup_type
    WriteupTypeEnum:
      enum:
      - update
      - development
      - capstone
      type: string
      description: |-
        * `update` - update
        * `development` - development
        * `capstone` - capstone
    ZoneEnum:
      enum:
      - fresh
      - strained
      - tired
      - overexerted
      - exhausted
      type: string
      description: |-
        * `fresh` - Fresh
        * `strained` - Strained
        * `tired` - Tired
        * `overexerted` - Overexerted
        * `exhausted` - Exhausted
    _CategoryPolish:
      type: object
      description: One polish category's value + derived tier label for a building.
      properties:
        category_id:
          type: integer
        category_name:
          type: string
        value:
          type: integer
        tier_label:
          type: string
          nullable: true
      required:
      - category_id
      - category_name
      - tier_label
      - value
    _Deed:
      type: object
      description: LegendEntry summary for the recent-deeds list.
      properties:
        id:
          type: integer
        title:
          type: string
        base_value:
          type: integer
        created_at:
          type: string
          format: date-time
      required:
      - base_value
      - created_at
      - id
      - title
    _DuelParticipantIdentity:
      type: object
      description: |-
        Compact identity for one side of a DuelChallenge (CharacterSheet id + name).

        Note: CharacterSheet's primary key is the ``character`` OneToOneField, so
        there is no ``.id`` attribute — ``source="pk"`` reads ``.pk`` explicitly.
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          description: Return the character's display name from CharacterSheet.character.db_key.
          readOnly: true
      required:
      - id
      - name
    _Fame:
      type: object
      description: Persona's fame state for the renown tab header.
      properties:
        points:
          type: integer
        tier:
          type: string
        tier_label:
          type: string
        tier_multiplier:
          type: number
          format: double
        next_tier:
          type: string
          nullable: true
        next_tier_threshold:
          type: integer
          nullable: true
      required:
      - next_tier
      - next_tier_threshold
      - points
      - tier
      - tier_label
      - tier_multiplier
    _NearXPLockProspect:
      type: object
      description: One entry in the near-xp-lock list returned by ThreadHubSummaryView.
      properties:
        thread_id:
          type: integer
        boundary_level:
          type: integer
        xp_cost:
          type: integer
        dev_points_to_boundary:
          type: integer
      required:
      - boundary_level
      - dev_points_to_boundary
      - thread_id
      - xp_cost
    _OwnedDwelling:
      type: object
      description: |-
        One building the persona owns, with polish breakdown + condition label.

        The renown payload is viewable by any authenticated player, so this
        carries only the public fiction: the qualitative condition-tier label
        (#1930, ADR-0031). Arrears / miss counters / mothball state are
        owner-only and surface through the owner action family instead.
      properties:
        id:
          type: integer
        name:
          type: string
        polish_by_category:
          type: array
          items:
            $ref: '#/components/schemas/_CategoryPolish'
        condition_label:
          type: string
      required:
      - condition_label
      - id
      - name
      - polish_by_category
    _PrestigeBreakdown:
      type: object
      description: Five-axis breakdown of the persona's total_prestige.
      properties:
        dwellings:
          type: integer
        items:
          type: integer
        orgs:
          type: integer
        deeds:
          type: integer
        fashion:
          type: integer
        total:
          type: integer
      required:
      - deeds
      - dwellings
      - fashion
      - items
      - orgs
      - total
    _RenownCardFame:
      type: object
      description: |-
        Fame block on the card — tier label only.

        The full Renown tab exposes numeric fame_points + multiplier for
        the player's own personas; foreign personas show just the tier
        label (the spec is explicit about no numeric reveal).
      properties:
        tier:
          type: string
        tier_label:
          type: string
      required:
      - tier
      - tier_label
    _ResonanceBalance:
      type: object
      description: One resonance balance entry returned by ThreadHubSummaryView.
      properties:
        resonance_id:
          type: integer
        balance:
          type: integer
        lifetime_earned:
          type: integer
        flavor_text:
          type: string
      required:
      - balance
      - flavor_text
      - lifetime_earned
      - resonance_id
    _SocietyReputation:
      type: object
      description: 'One reputation entry: society + tier label (no raw number).'
      properties:
        society_id:
          type: integer
        society_name:
          type: string
        tier:
          type: string
      required:
      - society_id
      - society_name
      - tier
    _TenantedRoom:
      type: object
      description: |-
        One room the persona tenants — polish breakdown only, no upkeep/dormancy.

        Upkeep + dormancy are building-level concepts; rooms don't carry
        them directly. The room's containing building's upkeep state shows
        up in ``owned_dwellings`` separately (when the persona owns it).
      properties:
        id:
          type: integer
        name:
          type: string
        polish_by_category:
          type: array
          items:
            $ref: '#/components/schemas/_CategoryPolish'
      required:
      - id
      - name
      - polish_by_category
    _WeavableTechnique:
      type: object
      description: One entry in the weavable_techniques list.
      properties:
        technique_id:
          type: integer
        name:
          type: string
        gift_id:
          type: integer
        gift_name:
          type: string
      required:
      - gift_id
      - gift_name
      - name
      - technique_id
    _WeavableTrait:
      type: object
      description: One entry in the weavable_traits list.
      properties:
        trait_id:
          type: integer
        name:
          type: string
        trait_type:
          type: string
        display_value:
          type: number
          format: double
      required:
      - display_value
      - name
      - trait_id
      - trait_type
  securitySchemes:
    cookieAuth:
      type: apiKey
      in: cookie
      name: sessionid
