        * `defender_decisive` - Defender — decisive
    Outcome88eEnum:
      enum:
      - victory
      - defeat
      - fled
      - abandoned
      type: string
      description: |-
        * `victory` - Victory
        * `defeat` - Defeat
        * `fled` - Fled
        * `abandoned` - Abandoned
    OutcomeD50Enum:
      enum:
      - unsatisfied
      - success
      - failure
      - expired
      - pending_gm_review
      type: string
      description: |-
        * `unsatisfied` - Unsatisfied
        * `success` - Success
        * `failure` - Failure
        * `expired` - Expired
        * `pending_gm_review` - Pending GM review
    OutcomeDetail:
      type: object
      properties:
        action_interaction_id:
          type: integer
        effects:
          type: array
          items:
            $ref: '#/components/schemas/EffectRow'
        power_ledger:
          allOf:
          - $ref: '#/components/schemas/PowerLedger'
          nullable: true
        strain_committed:
          type: integer
          nullable: true
        power:
          type: integer
          nullable: true
        progress_delta:
          type: integer
          nullable: true
      required:
      - action_interaction_id
      - effects
    OutcomeDisplayRow:
      type: object
      description: |-
        Schema-only shape of get_outcome_display rows (world.checks.types.OutcomeDisplay).

        Never instantiated for serialization — exists so drf-spectacular emits a
        concrete component instead of {[key: string]: unknown} (#2423).
      properties:
        label:
          type: string
        tier_name:
          type: string
        weight:
          type: integer
        is_selected:
          type: boolean
      required:
      - is_selected
      - label
      - tier_name
      - weight
    OutfitRead:
      type: object
      description: Read serializer for Outfit — nests slot rows.
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          readOnly: true
        description:
          type: string
          readOnly: true
        character_sheet:
          type: integer
          description: The character this sheet belongs to
          readOnly: true
        wardrobe:
          type: integer
          readOnly: true
          description: The wardrobe ItemInstance this outfit is stored in.
        slots:
          type: array
          items:
            $ref: '#/components/schemas/OutfitSlotRead'
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - character_sheet
      - created_at
      - description
      - id
      - name
      - slots
      - updated_at
      - wardrobe
    OutfitRenameRequest:
      type: object
      description: |-
        Write serializer for renames/redescribes (PUT / PATCH on Outfit).

        Distinct from ``OutfitWriteSerializer`` because update only touches
        ``name`` and ``description`` — exposing ``character_sheet`` and
        ``wardrobe`` in the request schema would imply they're editable when
        they're write-once. The viewset wires this serializer via
        ``@extend_schema`` on update/partial_update so the public API contract
        matches reality.
      properties:
        name:
          type: string
          minLength: 1
          maxLength: 100
        description:
          type: string
      required:
      - name
    OutfitSlotRead:
      type: object
      description: Read serializer for OutfitSlot — nests the item instance.
      properties:
        id:
          type: integer
          readOnly: true
        outfit:
          type: integer
          readOnly: true
        item_instance:
          allOf:
          - $ref: '#/components/schemas/ItemInstanceRead'
          readOnly: true
        body_region:
          allOf:
          - $ref: '#/components/schemas/BodyRegionEnum'
          readOnly: true
        equipment_layer:
          allOf:
          - $ref: '#/components/schemas/EquipmentLayerEnum'
          readOnly: true
      required:
      - body_region
      - equipment_layer
      - id
      - item_instance
      - outfit
    OutfitSlotWriteRequest:
      type: object
      description: |-
        Write serializer for OutfitSlot — validates POST input for AddOutfitSlotAction.

        ``OutfitSlotViewSet.create`` calls ``.is_valid()`` on this serializer and then
        dispatches through ``AddOutfitSlotAction`` directly (which wraps the
        ``add_outfit_slot`` service) rather than calling ``.save()`` — so this
        serializer has no ``create()`` override; it's validation-only.
      properties:
        outfit:
          type: integer
        item_instance:
          type: integer
        body_region:
          $ref: '#/components/schemas/BodyRegionEnum'
        equipment_layer:
          $ref: '#/components/schemas/EquipmentLayerEnum'
      required:
      - body_region
      - equipment_layer
      - item_instance
      - outfit
    OutfitWriteRequest:
      type: object
      description: |-
        Write serializer for Outfit — validates POST input for SaveOutfitAction.

        ``OutfitViewSet.create`` calls ``.is_valid()`` on this serializer and then
        dispatches through ``SaveOutfitAction`` directly (which wraps the
        ``save_outfit`` service) rather than calling ``.save()`` — so this
        serializer has no ``create()``/``update()`` override; it's validation-only.
      properties:
        name:
          type: string
          minLength: 1
          maxLength: 100
        description:
          type: string
        character_sheet:
          type: integer
          description: The character this sheet belongs to
        wardrobe:
          type: integer
          description: The wardrobe ItemInstance this outfit is stored in.
      required:
      - character_sheet
      - name
      - wardrobe
    OwnerModeEnum:
      enum:
      - PERSONAL
      - COVENANT
      type: string
      description: |-
        * `PERSONAL` - Personal (Persona-owned home)
        * `COVENANT` - Covenant (Organization-owned sacred ground)
    PaceModeEnum:
      enum:
      - timed
      - ready
      - manual
