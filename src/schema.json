        art_image:
          type: string
          format: uri
          description: URL for visual presentation
          maxLength: 200
        family_known:
          type: boolean
          description: Whether family is selectable in Lineage stage (False = 'Unknown')
        allowed_species_ids:
          type: array
          items:
            type: integer
