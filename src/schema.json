        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: page_size
        required: false
        in: query
        description: Number of results to return per page.
        schema:
          type: integer
      - in: query
        name: status
        schema:
          type: string
          enum:
          - changes_requested
          - cleared
          - pending
        description: |-
          * `pending` - Pending
          * `cleared` - Cleared
          * `changes_requested` - Changes requested
      - in: query
        name: tier
        schema:
          type: string
          enum:
          - regional
          - table
          - world
        description: |-
          * `table` - Table
          * `regional` - Regional
          * `world` - World
