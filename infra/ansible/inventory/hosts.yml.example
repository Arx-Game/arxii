---
# Real inventory is generated by standup.sh from `tofu output` (instance_ipv4)
# and is gitignored. This example documents the shape.
arxii_prod:
  hosts:
    prod:
      ansible_host: 203.0.113.10        # = tofu output instance_ipv4
      # ansible_user: first run = root (Linode injects the admin key there,
      # arxadmin doesn't exist yet); after base+ssh_hardening converge =
      # arxadmin (sudo, key-only). standup.sh probes both and picks
      # automatically — see select_ssh_user() there.
      ansible_user: arxadmin
      ansible_ssh_private_key_file: ~/.ssh/arxii_admin
