---
# Real inventory is generated by standup.sh from `tofu output` (instance_ipv4)
# and is gitignored. This example documents the shape.
arxii_prod:
  hosts:
    prod:
      ansible_host: 203.0.113.10        # = tofu output instance_ipv4
      ansible_user: arxii               # non-root; created by the base role's first run uses the bootstrap key
      ansible_ssh_private_key_file: ~/.ssh/arxii_admin
