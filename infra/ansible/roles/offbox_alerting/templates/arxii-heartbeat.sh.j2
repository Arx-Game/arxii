#!/usr/bin/env bash
# Managed by Ansible (offbox_alerting). Dead-man's-switch heartbeat + cert
# expiry early warning + failed-backup-unit detection. OFFBOX_ALERT_TOKEN
# (the check URL) from the EnvironmentFile; never echoed. The three "found a
# problem" paths below post via the shared arxii-alert helper (also
# installed by this role, before this script — see tasks/main.yml); only
# the final healthy ping at the bottom (a different endpoint, no "/fail"
# suffix) stays as its own direct curl.
set -euo pipefail
set +x

base="${OFFBOX_ALERT_TOKEN}"   # full base ping URL incl. the check id

# Failed backup/offsite units: these also carry their own OnFailure=
# alert-failure@ unit (fires immediately on failure), but a heartbeat check
# is a second, independent line of defense — it catches the case where the
# OnFailure= alert itself didn't fire/land (e.g. transient network blip at
# the moment of failure) by re-flagging the failed state on every heartbeat
# until someone clears it. arxii-telnet-cert.service is watched here too
# (#2236 review): its --require-cert flag was removed (a fresh stand-up's
# Persistent=true timer used to race Caddy's first ACME issuance, guaranteeing
# a spurious failed unit with nothing to clear it) — this is now the ONLY
# detector for a real cert-sync failure, alongside the self-signed check
# below. arxii-media-mirror.service (#2236 Phase 4) joins the same list —
# skipped entirely in rehearsal (role-level `when: offsite_enabled`), so
# `is-failed` on a nonexistent unit there just returns false, same as the
# other two in that mode.
failed_units=()
for u in arxii-backup.service arxii-offsite.service arxii-telnet-cert.service arxii-media-mirror.service; do
  if systemctl is-failed --quiet "${u}"; then
    failed_units+=("${u}")
  fi
done
# NOTE: the array-length substitution just below is deliberately NOT
# written as literal dollar-brace-hash-name-bracket bash syntax — Ansible's
# `template:` module runs this whole file through Jinja2, and that literal
# substring opens what Jinja parses as an (unterminated, since nothing else
# in this file closes it) comment, failing the ENTIRE template's rendering
# with "Missing end of comment tag" (a real, pre-existing bug found while
# validating #2236's other changes to this file — the whole offbox_alerting
# role would fail to converge). The `{{ '{#' }}` below is Jinja's standard
# escape for a literal dollar-brace-hash sequence.
if [ "${{ '{#' }}failed_units[@]}" -gt 0 ]; then
  /usr/local/sbin/arxii-alert "backup unit(s) in failed state: ${failed_units[*]}"
  exit 0
fi

# Cert-expiry: if the SSL-telnet/web cert expires within the warn window,
# signal the /fail endpoint so the external service alerts EARLY.
if [ -f "{{ offbox_cert_path }}" ]; then
  end="$(openssl x509 -enddate -noout -in "{{ offbox_cert_path }}" | cut -d= -f2)"
  end_s="$(date -d "$end" +%s)"
  now_s="$(date +%s)"
  if [ $(( (end_s - now_s) / 86400 )) -lt {{ offbox_cert_warn_days }} ]; then
    /usr/local/sbin/arxii-alert "cert expiring <{{ offbox_cert_warn_days }}d"
    exit 0
  fi

  # Self-signed detection: Evennia auto-generates a self-signed cert (~20yr
  # validity) the FIRST time it starts without ssl.cert/ssl.key present.
  # That masks the real failure mode — Caddy's ACME cert never got synced
  # (tls_telnet_cert's timer hasn't run yet, or DNS-01 has been silently
  # failing since e.g. the caddy-dns/cloudflare plugin got dropped by a
  # plain apt upgrade) — because a 20-year cert sails straight past the
  # expiry check above. Issuer == Subject is the hallmark of a self-signed
  # cert; flag it explicitly instead of trusting a distant expiry date.
  issuer="$(openssl x509 -issuer -noout -in "{{ offbox_cert_path }}" 2>/dev/null || true)"
  subject="$(openssl x509 -subject -noout -in "{{ offbox_cert_path }}" 2>/dev/null || true)"
  if [ -n "${issuer}" ] && [ "${issuer#issuer=}" = "${subject#subject=}" ]; then
    /usr/local/sbin/arxii-alert "telnet cert is self-signed (Caddy cert never synced)"
    exit 0
  fi
fi

# Healthy: ping success (silence => the external service raises the alarm).
curl -fsS -m 10 "${base}" >/dev/null || true
