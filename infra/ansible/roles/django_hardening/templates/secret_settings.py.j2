# Managed by Ansible (django_hardening). Evennia imports server/conf/
# secret_settings.py last (gitignored convention) — this is the prod
# hardening overlay. NO secret VALUES here: everything sensitive comes from
# os.environ (the systemd EnvironmentFile rendered by secrets_vault).
import os

DEBUG = False
SECRET_KEY = os.environ["DJANGO_SECRET_KEY"]
ALLOWED_HOSTS = {{ dh_allowed_hosts | to_json }}

# Cookies / proxy chain (Cloudflare -> Caddy -> localhost app)
SESSION_COOKIE_SECURE = True
CSRF_COOKIE_SECURE = True
SECURE_SSL_REDIRECT = True
SECURE_PROXY_SSL_HEADER = ("HTTP_X_FORWARDED_PROTO", "https")
CSRF_TRUSTED_ORIGINS = ["https://%s" % h for h in ALLOWED_HOSTS]

# Telnet: TLS-only. Plaintext listener NOT bound. Web/WS backend bound to
# localhost (only Caddy reaches it); the public SSL-telnet listener stays
# externally bound.
TELNET_ENABLED = False
SSL_ENABLED = True
WEBSERVER_INTERFACES = ["127.0.0.1"]
WEBSOCKET_CLIENT_INTERFACE = "127.0.0.1"
# Verified against the vendored evennia.settings_default (WEBSOCKET_CLIENT_URL
# docstring: "ws[s]://hostname[:port]", used by Evennia's own /webclient page
# to know where to open its websocket — see web/templates/webclient/base.html
# + web/static/webclient/js/evennia.js, which does `new WebSocket(wsurl + '?'
# + csessid + ...)`, i.e. wsurl is used verbatim with only a query string
# appended). A bare "wss://host" here (no path) would route through Caddy's
# catch-all `handle {}` (the Django/web backend on :4001, NOT websocket-
# capable) instead of the `@ws path /ws/*` route to the portal on :4002 — so
# this includes a trailing-slash "/ws/" path (a deliberate deviation from the
# setting's documented no-path form) to land inside the @ws matcher.
WEBSOCKET_CLIENT_URL = "wss://{{ dh_web_fqdn }}/ws/"
LOCKDOWN_MODE = False

# Postgres (localhost; password from env)
DATABASES = {
    "default": {
        "ENGINE": "django.db.backends.postgresql",
        "NAME": "arxii",
        "USER": "arxii",
        "PASSWORD": os.environ["POSTGRES_PASSWORD"],
        "HOST": "127.0.0.1",
        "PORT": "5432",
    }
}

# Transactional email via Resend SMTP relay (NO on-box MTA).
EMAIL_BACKEND = "django.core.mail.backends.smtp.EmailBackend"
EMAIL_HOST = "smtp.resend.com"
EMAIL_PORT = 587
EMAIL_USE_TLS = True
EMAIL_HOST_USER = "resend"
EMAIL_HOST_PASSWORD = os.environ["RESEND_API_KEY"]
DEFAULT_FROM_EMAIL = "{{ dh_default_from_email }}"

# App-layer rate limiting (abuse / credential-stuffing on login & account
# creation). Cloudflare handles the web edge; these are the Evennia-side
# throttles. Confirm exact setting names against the deployed Evennia
# version in CI/runbook (flagged, not faked).
MAX_COMMAND_RATE = 80          # commands/sec per session before throttling
COMMAND_RATE_WARN = "Slow down."
MAX_CHAR_LIMIT = 6000
CONNECTION_RATE_LIMIT = 5      # new connections/min per IP
