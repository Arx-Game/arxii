#!/usr/bin/env bash
# Managed by Ansible (offsite_replication). Push the latest dump to the
# INDEPENDENT R2 offsite copy using ONLY the separate R2 credential. NEVER
# restores, NEVER deletes remote. Creds from EnvironmentFile (no echo).
set -euo pipefail
set +x

src="{{ offsite_staging_latest }}"
[ -e "$src" ] || { echo "no local dump to replicate yet"; exit 0; }
real="$(readlink -f "$src")"
key="db/$(basename "$real")"

AWS_ACCESS_KEY_ID="${R2_ACCESS_KEY_ID}" \
AWS_SECRET_ACCESS_KEY="${R2_SECRET_ACCESS_KEY}" \
aws --endpoint-url "{{ offsite_r2_endpoint }}" --region auto \
    s3 cp "$real" "s3://{{ offsite_r2_bucket }}/${key}"
