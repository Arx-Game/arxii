{# Rendered with no_log:true. 0600 service-user. Public-repo-safe: this
   template has NO secret values — only env-var name mappings (plus a
   couple of values computed FROM those same env vars below); the actual
   secret values come from lookup('env',...) at run time from the gated
   Environment. #}
# Managed by Ansible (secrets_vault). DO NOT edit; not in version control.
{% for src, dest in secrets_map.items() %}
{{ dest }}={{ lookup('env', src) }}
{% endfor %}

# DATABASE_URL: django-environ's env.db() (src/server/conf/settings.py)
# parses this directly — settings.py has no discrete-PG*-vars path. The
# password is urlencode-filtered so special characters in a generated
# password (@, :, /, etc.) survive URL parsing intact. User/db name mirror
# roles/postgres/defaults/main.yml's postgres_db_user/postgres_db_name
# ("arxii") — keep in lockstep if those ever change. POSTGRES_PASSWORD
# (rendered above, from the secrets_map loop) stays too: the postgres
# role's own tasks, the backup script, and psql's PGPASSWORD all read that
# key directly, never DATABASE_URL.
DATABASE_URL=postgres://arxii:{{ lookup('env', 'ARXII_PG_PASSWORD') | urlencode }}@127.0.0.1:5432/arxii

# FRONTEND_URL / SITE_URL: settings.py reads both via env() at its own
# normal (pre-overlay) import time and immediately derives further values
# from FRONTEND_URL (allauth headless redirect URLs, CSRF_TRUSTED_ORIGINS).
# The django_hardening overlay imports LAST (see settings.py's guarded
# `from server.conf.secret_settings import *`), so setting FRONTEND_URL
# there would be too late to affect those already-derived values. Providing
# both here instead — before settings.py ever runs — lets settings.py's own
# derivation logic pick up the real prod domain with no overlay involvement
# at all. dh_web_fqdn is a group_var (generated by standup.sh from the tofu
# `web_fqdn` output), available here regardless of secrets_vault's position
# in site.yml's role order (group_vars apply to the whole play up front).
FRONTEND_URL=https://{{ dh_web_fqdn }}
SITE_URL=https://{{ dh_web_fqdn }}
