#!/usr/bin/env bash
# Managed by Ansible (backups). pg_dump -> Linode Object Storage primary.
# NEVER restores. Creds from the systemd EnvironmentFile (no echo; set +x).
set -euo pipefail
set +x

ts="$(date -u +%Y%m%dT%H%M%SZ)"
mkdir -p "{{ backups_staging }}"
dump="{{ backups_staging }}/arxii-${ts}.sql.gz"

pg_dump -U "{{ backups_db_user }}" -h 127.0.0.1 "{{ backups_db }}" | gzip -9 > "$dump"

AWS_ACCESS_KEY_ID="${BACKUP_WRITER_ACCESS_KEY}" \
AWS_SECRET_ACCESS_KEY="${BACKUP_WRITER_SECRET_KEY}" \
aws --endpoint-url "{{ backups_s3_endpoint }}" --region "{{ backups_region }}" \
    s3 cp "$dump" "s3://{{ backups_bucket }}/db/arxii-${ts}.sql.gz"

# Keep only the newest local copy (the offsite job consumes it). Server-side
# retention/immutability is Object Lock on the bucket, not this client.
ls -1t "{{ backups_staging }}"/arxii-*.sql.gz | tail -n +2 | xargs -r rm -f
ln -sf "$dump" "{{ backups_staging }}/latest.sql.gz"
